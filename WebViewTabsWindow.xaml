
<Window x:Class="RoleplayOverlay.WebViewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="Web"
        Width="1100" Height="720"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        Background="{DynamicResource Bg}">
  <Window.Resources>
    <SolidColorBrush x:Key="Bg"    Color="#0B0B0C"/>
    <SolidColorBrush x:Key="Bg2"   Color="#141416"/>
    <SolidColorBrush x:Key="Line"  Color="#2A2B2E"/>
    <SolidColorBrush x:Key="Fg"    Color="#EAEAEA"/>
    <SolidColorBrush x:Key="Fg2"   Color="#C8C8C8"/>
    <SolidColorBrush x:Key="Accent" Color="#7C7C7C"/>

    <Style x:Key="ToolbarButton" TargetType="Button">
      <Setter Property="Foreground" Value="{DynamicResource Fg}"/>
      <Setter Property="Background" Value="{DynamicResource Bg2}"/>
      <Setter Property="BorderBrush" Value="{DynamicResource Line}"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="Padding" Value="10,6"/>
      <Setter Property="Margin" Value="6,0,0,0"/>
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="SnapsToDevicePixels" Value="True"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="8">
              <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#1C1D20"/>
              </Trigger>
              <Trigger Property="IsPressed" Value="True">
                <Setter Property="Background" Value="#222327"/>
              </Trigger>
              <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Opacity" Value="0.45"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style TargetType="TextBox">
      <Setter Property="Foreground" Value="{DynamicResource Fg}"/>
      <Setter Property="Background" Value="#111113"/>
      <Setter Property="BorderBrush" Value="{DynamicResource Line}"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="Padding" Value="10,6"/>
      <Setter Property="Margin" Value="6,0,0,0"/>
      <Setter Property="VerticalContentAlignment" Value="Center"/>
      <Setter Property="SnapsToDevicePixels" Value="True"/>
    </Style>

    <Style TargetType="Separator">
      <Setter Property="Background" Value="{DynamicResource Line}"/>
      <Setter Property="Margin" Value="10,0"/>
      <Setter Property="Width" Value="1"/>
    </Style>
  </Window.Resources>

  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="44"/>
      <RowDefinition Height="*"/>
    </Grid.RowDefinitions>

    <Border Grid.Row="0" Background="{DynamicResource Bg2}" BorderBrush="{DynamicResource Line}" BorderThickness="0,0,0,1">
      <DockPanel LastChildFill="True">
        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="8,4" DockPanel.Dock="Left">
          <Button x:Name="BtnBack"    Style="{StaticResource ToolbarButton}" Content="⟵" Click="OnBack"/>
          <Button x:Name="BtnForward" Style="{StaticResource ToolbarButton}" Content="⟶" Click="OnForward"/>
          <Button x:Name="BtnReload"  Style="{StaticResource ToolbarButton}" Content="↻"  Click="OnReload"/>
        </StackPanel>
        <TextBox x:Name="AddressBox" DockPanel.Dock="Right" Margin="8,6,8,6" KeyDown="OnAddressKeyDown" />
      </DockPanel>
    </Border>

    <Border Grid.Row="1" Background="{DynamicResource Bg}">
      <wv2:WebView2 x:Name="Web"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"/>
    </Border>
  </Grid>
</Window>