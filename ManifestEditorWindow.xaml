<Window x:Class="RoleplayOverlay.ManifestEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:RoleplayOverlay"
        Title="Éditeur de Manifest — Assignation Slides ↔ Séquences"
        Height="720" MinHeight="560"
        Width="1300" MinWidth="900"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="#0B0B0C">

  <Window.Resources>

    <SolidColorBrush x:Key="Bg"       Color="#0B0B0C"/>
    <SolidColorBrush x:Key="Bg2"      Color="#141416"/>
    <SolidColorBrush x:Key="Bg3"      Color="#1C1D20"/>
    <SolidColorBrush x:Key="Line"     Color="#2A2B2E"/>
    <SolidColorBrush x:Key="Fg"       Color="#EAEAEA"/>
    <SolidColorBrush x:Key="Fg2"      Color="#9A9A9A"/>
    <SolidColorBrush x:Key="Accent"   Color="#E84118"/>
    <SolidColorBrush x:Key="AccentDim" Color="#7C1A0E"/>
    <SolidColorBrush x:Key="DropHl"  Color="#33E84118"/>

    <Style x:Key="DBtn" TargetType="Button">
      <Setter Property="Foreground"       Value="{StaticResource Fg}"/>
      <Setter Property="Background"       Value="{StaticResource Bg3}"/>
      <Setter Property="BorderBrush"      Value="{StaticResource Line}"/>
      <Setter Property="BorderThickness"  Value="1"/>
      <Setter Property="Padding"          Value="12,6"/>
      <Setter Property="Cursor"           Value="Hand"/>
      <Setter Property="SnapsToDevicePixels" Value="True"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="6" Padding="{TemplateBinding Padding}">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#252628"/>
              </Trigger>
              <Trigger Property="IsPressed"   Value="True">
                <Setter Property="Background" Value="#2C2D30"/>
              </Trigger>
              <Trigger Property="IsEnabled"   Value="False">
                <Setter Property="Opacity"    Value="0.4"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style x:Key="AccBtn" TargetType="Button" BasedOn="{StaticResource DBtn}">
      <Setter Property="Background"  Value="{StaticResource Accent}"/>
      <Setter Property="BorderBrush" Value="{StaticResource AccentDim}"/>
      <Setter Property="FontWeight"  Value="SemiBold"/>
      <Style.Triggers>
        <Trigger Property="IsMouseOver" Value="True">
          <Setter Property="Background" Value="#FF5733"/>
        </Trigger>
      </Style.Triggers>
    </Style>

    <Style x:Key="IcoBtn" TargetType="Button" BasedOn="{StaticResource DBtn}">
      <Setter Property="Padding"   Value="7,4"/>
      <Setter Property="FontSize"  Value="12"/>
      <Setter Property="MinWidth"  Value="28"/>
    </Style>

    <Style TargetType="TextBox">
      <Setter Property="Foreground"        Value="{StaticResource Fg}"/>
      <Setter Property="Background"        Value="#111113"/>
      <Setter Property="BorderBrush"       Value="{StaticResource Line}"/>
      <Setter Property="BorderThickness"   Value="1"/>
      <Setter Property="Padding"           Value="7,4"/>
      <Setter Property="CaretBrush"        Value="{StaticResource Fg}"/>
      <Setter Property="VerticalContentAlignment" Value="Center"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="TextBox">
            <Border Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="5">
              <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"/>
            </Border>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style TargetType="CheckBox">
      <Setter Property="Foreground"             Value="{StaticResource Fg2}"/>
      <Setter Property="VerticalContentAlignment" Value="Center"/>
    </Style>

    <Style TargetType="ScrollBar">
      <Setter Property="Width"      Value="6"/>
      <Setter Property="Background" Value="Transparent"/>
    </Style>

    <Style x:Key="SecLbl" TargetType="TextBlock">
      <Setter Property="Foreground" Value="{StaticResource Fg2}"/>
      <Setter Property="FontSize"   Value="10"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>

  </Window.Resources>

  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="48"/>
      <RowDefinition Height="1"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="1"/>
      <RowDefinition Height="44"/>
    </Grid.RowDefinitions>

    <Border Grid.Row="0" Background="{StaticResource Bg2}">
      <DockPanel Margin="12,0" LastChildFill="False">

        <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center">
          <TextBlock Text="🗂" FontSize="18" Margin="0,0,10,0" VerticalAlignment="Center"/>
          <TextBlock Text="MANIFEST EDITOR" FontSize="11" FontWeight="Bold"
                     Foreground="{StaticResource Fg}" VerticalAlignment="Center"/>

          <Border Width="1" Background="{StaticResource Line}" Margin="16,10"/>

          <TextBlock Text="Dossier slides :" Foreground="{StaticResource Fg2}"
                     FontSize="11" VerticalAlignment="Center" Margin="0,0,8,0"/>
          <TextBox x:Name="SlidesDirBox" Width="300" VerticalAlignment="Center"
                   ToolTip="Dossier contenant les fichiers PNG/JPG des slides"/>
          <Button Content="📁" Style="{StaticResource IcoBtn}" Margin="6,0,0,0"
                  Click="OnBrowseSlidesDir" ToolTip="Parcourir…"/>
          <Button Content="↻ Scan" Style="{StaticResource IcoBtn}" Margin="6,0,0,0"
                  Click="OnScanSlides"
                  ToolTip="Scanner le dossier et détecter les slides automatiquement"/>
        </StackPanel>

        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal"
                    VerticalAlignment="Center">
          <Button Content="💾 Sauvegarder manifest" Style="{StaticResource DBtn}"
                  Click="OnSaveManifest" ToolTip="Sauvegarder le .render.json"/>
          <Button Content="⬛ Lancer l'export MP4" Style="{StaticResource AccBtn}"
                  Click="OnExportMp4" ToolTip="Sauvegarder et lancer le rendu FFmpeg"/>
        </StackPanel>

      </DockPanel>
    </Border>

    <Border Grid.Row="1" Background="{StaticResource Line}"/>

    <Grid Grid.Row="2">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="260" MinWidth="200"/>
        <ColumnDefinition Width="1"/>
        <ColumnDefinition Width="*"   MinWidth="380"/>
        <ColumnDefinition Width="1"/>
        <ColumnDefinition Width="300" MinWidth="240"/>
      </Grid.ColumnDefinitions>

      <Grid Grid.Column="0">
        <Grid.RowDefinitions>
          <RowDefinition Height="38"/>
          <RowDefinition Height="1"/>
          <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource Bg2}" Padding="10,0">
          <DockPanel VerticalAlignment="Center">
            <TextBlock Text="SÉQUENCES" Style="{StaticResource SecLbl}"
                       VerticalAlignment="Center"/>
            <TextBlock x:Name="SeqCountLabel"
                       DockPanel.Dock="Right"
                       Foreground="{StaticResource Fg2}" FontSize="10"
                       VerticalAlignment="Center" Text="0"/>
          </DockPanel>
        </Border>

        <Border Grid.Row="1" Background="{StaticResource Line}"/>

        <ListBox x:Name="SeqPool"
                 Grid.Row="2"
                 Background="Transparent"
                 BorderThickness="0"
                 Foreground="{StaticResource Fg}"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                 PreviewMouseLeftButtonDown="OnSeqPoolMouseDown"
                 MouseMove="OnSeqPoolMouseMove">
          <ListBox.ItemTemplate>
            <DataTemplate>
              <Border Padding="8,5" Margin="0,1" CornerRadius="4">
                <Border.Style>
                  <Style TargetType="Border">
                    <Style.Triggers>
                      <DataTrigger Binding="{Binding IsAssigned}" Value="True">
                        <Setter Property="Opacity" Value="0.4"/>
                      </DataTrigger>
                    </Style.Triggers>
                  </Style>
                </Border.Style>
                <StackPanel>
                  <StackPanel Orientation="Horizontal" Margin="0,0,0,2">

                    <Border CornerRadius="3" Padding="4,1" Margin="0,0,6,0">
                      <Border.Style>
                        <Style TargetType="Border">
                          <Style.Triggers>
                            <DataTrigger Binding="{Binding Speaker}" Value="you">
                              <Setter Property="Background" Value="#33FFD400"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Speaker}" Value="bot1">
                              <Setter Property="Background" Value="#2200DFFF"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Speaker}" Value="bot2">
                              <Setter Property="Background" Value="#22FF00C8"/>
                            </DataTrigger>
                          </Style.Triggers>
                        </Style>
                      </Border.Style>
                      <TextBlock FontSize="9" FontWeight="Bold">
                        <TextBlock.Style>
                          <Style TargetType="TextBlock">
                            <Style.Triggers>
                              <DataTrigger Binding="{Binding Speaker}" Value="you">
                                <Setter Property="Text"       Value="YOU"/>
                                <Setter Property="Foreground" Value="#FFD400"/>
                              </DataTrigger>
                              <DataTrigger Binding="{Binding Speaker}" Value="bot1">
                                <Setter Property="Text"       Value="B1"/>
                                <Setter Property="Foreground" Value="#00DFFF"/>
                              </DataTrigger>
                              <DataTrigger Binding="{Binding Speaker}" Value="bot2">
                                <Setter Property="Text"       Value="B2"/>
                                <Setter Property="Foreground" Value="#FF00C8"/>
                              </DataTrigger>
                            </Style.Triggers>
                          </Style>
                        </TextBlock.Style>
                      </TextBlock>
                    </Border>

                    <Border CornerRadius="3" Padding="4,1">
                      <Border.Style>
                        <Style TargetType="Border">
                          <Style.Triggers>
                            <DataTrigger Binding="{Binding Mode}" Value="mp3">
                              <Setter Property="Background" Value="#22E84118"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Mode}" Value="tts">
                              <Setter Property="Background" Value="#221A6B3C"/>
                            </DataTrigger>
                          </Style.Triggers>
                        </Style>
                      </Border.Style>
                      <TextBlock FontSize="9" FontWeight="Bold">
                        <TextBlock.Style>
                          <Style TargetType="TextBlock">
                            <Style.Triggers>
                              <DataTrigger Binding="{Binding Mode}" Value="mp3">
                                <Setter Property="Text"       Value="MP3"/>
                                <Setter Property="Foreground" Value="#E84118"/>
                              </DataTrigger>
                              <DataTrigger Binding="{Binding Mode}" Value="tts">
                                <Setter Property="Text"       Value="TTS"/>
                                <Setter Property="Foreground" Value="#4DC93C"/>
                              </DataTrigger>
                            </Style.Triggers>
                          </Style>
                        </TextBlock.Style>
                      </TextBlock>
                    </Border>
                  </StackPanel>

                  <TextBlock Text="{Binding PreviewText}"
                             FontSize="11" Foreground="{StaticResource Fg}"
                             TextTrimming="CharacterEllipsis"
                             MaxWidth="220"/>

                  <TextBlock Text="{Binding ShortId}"
                             FontSize="9" Foreground="{StaticResource Fg2}"
                             FontFamily="Consolas"/>
                </StackPanel>
              </Border>
            </DataTemplate>
          </ListBox.ItemTemplate>

          <ListBox.ItemContainerStyle>
            <Style TargetType="ListBoxItem">
              <Setter Property="Background"  Value="Transparent"/>
              <Setter Property="Padding"     Value="0"/>
              <Setter Property="Cursor"      Value="Hand"/>
              <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
              <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                  <Setter Property="Background" Value="#88E84118"/>
                  <Setter Property="BorderBrush" Value="#E84118"/>
                  <Setter Property="BorderThickness" Value="3,0,0,0"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                  <Setter Property="Background" Value="#10FFFFFF"/>
                </Trigger>
              </Style.Triggers>
            </Style>
          </ListBox.ItemContainerStyle>
        </ListBox>
      </Grid>

      <Border Grid.Column="1" Background="{StaticResource Line}"/>

      <Grid Grid.Column="2">
        <Grid.RowDefinitions>
          <RowDefinition Height="38"/>
          <RowDefinition Height="1"/>
          <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource Bg2}" Padding="10,0">
          <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
            <TextBlock Text="SEGMENTS" Style="{StaticResource SecLbl}" VerticalAlignment="Center"/>
            <Border Width="1" Background="{StaticResource Line}" Margin="4,8"/>
            <Button Content="+ Segment" Style="{StaticResource IcoBtn}" Click="OnAddSegment"
                    ToolTip="Ajouter un segment vide"/>
            <Button Content="Auto-assigner" Style="{StaticResource IcoBtn}" Click="OnAutoAssign"
                    ToolTip="Assigner automatiquement les séquences aux segments par ordre"/>
            <Button Content="▲" Style="{StaticResource IcoBtn}" Click="OnSegUp"
                    ToolTip="Monter le segment sélectionné"/>
            <Button Content="▼" Style="{StaticResource IcoBtn}" Click="OnSegDown"
                    ToolTip="Descendre le segment sélectionné"/>
            <Button Content="✕" Style="{StaticResource IcoBtn}" Click="OnSegDelete"
                    ToolTip="Supprimer le segment sélectionné"/>
          </StackPanel>
        </Border>

        <Border Grid.Row="1" Background="{StaticResource Line}"/>

        <ScrollViewer Grid.Row="2"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
          <ItemsControl x:Name="SegmentList"
                        Background="Transparent"
                        Padding="8">
            <ItemsControl.ItemTemplate>
              <DataTemplate>

                <Border x:Name="SegCard"
                        Margin="0,0,0,8"
                        CornerRadius="8"
                        BorderThickness="1"
                        Padding="0"
                        AllowDrop="True"
                        Drop="OnSegmentDrop"
                        DragOver="OnSegmentDragOver"
                        DragLeave="OnSegmentDragLeave"
                        MouseLeftButtonDown="OnSegmentCardClick"
                        Tag="{Binding}">
                  <Border.Background>
                    <SolidColorBrush Color="#141416"/>
                  </Border.Background>
                  <Border.BorderBrush>
                    <SolidColorBrush Color="#2A2B2E"/>
                  </Border.BorderBrush>
                  <Border.Style>
                    <Style TargetType="Border">
                      <Style.Triggers>
                        <DataTrigger Binding="{Binding IsSelected}" Value="True">
                          <Setter Property="BorderBrush"
                                  Value="#E84118"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding IsDragOver}" Value="True">
                          <Setter Property="Background">
                            <Setter.Value>
                              <SolidColorBrush Color="#1AE84118"/>
                            </Setter.Value>
                          </Setter>
                          <Setter Property="BorderBrush" Value="#E84118"/>
                        </DataTrigger>
                      </Style.Triggers>
                    </Style>
                  </Border.Style>

                  <Grid>
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="90"/>
                      <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            CornerRadius="7,0,0,7"
                            Background="#0D0D0F"
                            ClipToBounds="True">
                      <Grid>

                        <Image x:Name="ThumbImage"
                               Source="{Binding SlideThumbnail}"
                               Stretch="UniformToFill"
                               RenderOptions.BitmapScalingMode="HighQuality"/>

                        <Button Content="🖼"
                                FontSize="20"
                                Background="Transparent"
                                BorderThickness="0"
                                Cursor="Hand"
                                ToolTip="Changer la slide…"
                                Tag="{Binding}"
                                Click="OnPickSlide"
                                Visibility="{Binding HasSlide,
                                  Converter={x:Static local:BoolToVisibilityConverter.Collapsed}}"/>

                        <TextBlock Text="+ Slide"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Foreground="#555"
                                   FontSize="11"
                                   Visibility="{Binding HasSlide,
                                     Converter={x:Static local:BoolToVisibilityConverter.Collapsed}}"/>
                      </Grid>
                    </Border>

                    <StackPanel Grid.Column="1" Margin="10,8,8,8">

                      <DockPanel Margin="0,0,0,4">
                        <Button DockPanel.Dock="Right"
                                Content="🖼" FontSize="11"
                                Style="{StaticResource IcoBtn}"
                                Tag="{Binding}"
                                Click="OnPickSlide"
                                ToolTip="Assigner une slide à ce segment"/>
                        <TextBox Text="{Binding Label, UpdateSourceTrigger=PropertyChanged}"
                                 FontWeight="SemiBold" FontSize="12"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Padding="0"
                                 Foreground="{StaticResource Fg}"/>
                      </DockPanel>

                      <TextBlock Text="{Binding SlideFileName}"
                                 FontSize="10" Foreground="{StaticResource Fg2}"
                                 FontFamily="Consolas"
                                 TextTrimming="CharacterEllipsis"
                                 Margin="0,0,0,6"/>

                      <ItemsControl x:Name="AssignedSeqs"
                                    ItemsSource="{Binding AssignedSequences}">
                        <ItemsControl.ItemTemplate>
                          <DataTemplate>
                            <Border Margin="0,0,0,3" CornerRadius="4"
                                    Background="#0DFFFFFF" Padding="6,3">
                              <DockPanel>
                                <Button DockPanel.Dock="Right"
                                        Content="✕" FontSize="9"
                                        Style="{StaticResource IcoBtn}"
                                        Padding="3,1"
                                        Tag="{Binding}"
                                        Click="OnUnassignSeq"
                                        ToolTip="Retirer cette séquence du segment"/>
                                <StackPanel>

                                  <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
                                    <Border CornerRadius="3" Padding="3,0" Margin="0,0,4,0">
                                      <Border.Style>
                                        <Style TargetType="Border">
                                          <Style.Triggers>
                                            <DataTrigger Binding="{Binding Speaker}" Value="you">
                                              <Setter Property="Background" Value="#33FFD400"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Speaker}" Value="bot1">
                                              <Setter Property="Background" Value="#2200DFFF"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Speaker}" Value="bot2">
                                              <Setter Property="Background" Value="#22FF00C8"/>
                                            </DataTrigger>
                                          </Style.Triggers>
                                        </Style>
                                      </Border.Style>
                                      <TextBlock FontSize="8" FontWeight="Bold">
                                        <TextBlock.Style>
                                          <Style TargetType="TextBlock">
                                            <Style.Triggers>
                                              <DataTrigger Binding="{Binding Speaker}" Value="you">
                                                <Setter Property="Text" Value="YOU"/>
                                                <Setter Property="Foreground" Value="#FFD400"/>
                                              </DataTrigger>
                                              <DataTrigger Binding="{Binding Speaker}" Value="bot1">
                                                <Setter Property="Text" Value="B1"/>
                                                <Setter Property="Foreground" Value="#00DFFF"/>
                                              </DataTrigger>
                                              <DataTrigger Binding="{Binding Speaker}" Value="bot2">
                                                <Setter Property="Text" Value="B2"/>
                                                <Setter Property="Foreground" Value="#FF00C8"/>
                                              </DataTrigger>
                                            </Style.Triggers>
                                          </Style>
                                        </TextBlock.Style>
                                      </TextBlock>
                                    </Border>
                                    <Border CornerRadius="3" Padding="3,0">
                                      <Border.Style>
                                        <Style TargetType="Border">
                                          <Style.Triggers>
                                            <DataTrigger Binding="{Binding Mode}" Value="mp3">
                                              <Setter Property="Background" Value="#22E84118"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Mode}" Value="tts">
                                              <Setter Property="Background" Value="#221A6B3C"/>
                                            </DataTrigger>
                                          </Style.Triggers>
                                        </Style>
                                      </Border.Style>
                                      <TextBlock FontSize="8" FontWeight="Bold">
                                        <TextBlock.Style>
                                          <Style TargetType="TextBlock">
                                            <Style.Triggers>
                                              <DataTrigger Binding="{Binding Mode}" Value="mp3">
                                                <Setter Property="Text" Value="MP3"/>
                                                <Setter Property="Foreground" Value="#E84118"/>
                                              </DataTrigger>
                                              <DataTrigger Binding="{Binding Mode}" Value="tts">
                                                <Setter Property="Text" Value="TTS"/>
                                                <Setter Property="Foreground" Value="#4DC93C"/>
                                              </DataTrigger>
                                            </Style.Triggers>
                                          </Style>
                                        </TextBlock.Style>
                                      </TextBlock>
                                    </Border>
                                  </StackPanel>

                                  <TextBlock Text="{Binding PreviewText}"
                                             FontSize="10" Foreground="{StaticResource Fg}"
                                             TextTrimming="CharacterEllipsis"/>
                                </StackPanel>
                              </DockPanel>
                            </Border>
                          </DataTemplate>
                        </ItemsControl.ItemTemplate>
                      </ItemsControl>

                      <Border Margin="0,4,0,0" CornerRadius="4"
                              Background="#08FFFFFF" Padding="6,4">
                        <StackPanel>
                          <DockPanel Margin="0,0,0,3">
                            <TextBlock Text="🎬 Média" FontSize="9" FontWeight="SemiBold"
                                       Foreground="{StaticResource Fg2}" VerticalAlignment="Center"/>
                            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                              <Button Content="📂" FontSize="9"
                                      Style="{StaticResource IcoBtn}" Padding="4,1"
                                      Tag="{Binding}" Click="OnPickMedia"
                                      ToolTip="Assigner un média (PNG/GIF/MP4)"/>
                              <Button Content="✕" FontSize="9"
                                      Style="{StaticResource IcoBtn}" Padding="4,1"
                                      Tag="{Binding}" Click="OnClearMedia"
                                      ToolTip="Retirer le média"/>
                            </StackPanel>
                          </DockPanel>

                          <TextBlock Text="{Binding MediaFileName}"
                                     FontSize="9" Foreground="{StaticResource Fg}"
                                     FontFamily="Consolas"
                                     TextTrimming="CharacterEllipsis"
                                     Margin="0,2,0,0">
                            <TextBlock.Style>
                              <Style TargetType="TextBlock">
                                <Style.Triggers>
                                  <DataTrigger Binding="{Binding MediaFileName}" Value="">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                  </DataTrigger>
                                </Style.Triggers>
                              </Style>
                            </TextBlock.Style>
                          </TextBlock>

                          <StackPanel Margin="0,4,0,0">
                            <StackPanel.Style>
                              <Style TargetType="StackPanel">
                                <Style.Triggers>
                                  <DataTrigger Binding="{Binding MediaFileName}" Value="">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                  </DataTrigger>
                                </Style.Triggers>
                              </Style>
                            </StackPanel.Style>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,3">
                              <TextBlock Text="Scale :" FontSize="9"
                                         Foreground="{StaticResource Fg2}"
                                         VerticalAlignment="Center" Margin="0,0,4,0"/>
                              <TextBox Text="{Binding MediaScale, UpdateSourceTrigger=PropertyChanged}"
                                       Width="36" FontSize="9" Padding="2,1"
                                       ToolTip="Échelle du média (0.1–1.0)"/>
                              <TextBlock Text="Vitesse :" FontSize="9"
                                         Foreground="{StaticResource Fg2}"
                                         VerticalAlignment="Center" Margin="8,0,4,0"/>
                              <TextBox Text="{Binding MediaSpeed, UpdateSourceTrigger=PropertyChanged}"
                                       Width="36" FontSize="9" Padding="2,1"
                                       ToolTip="Vitesse de lecture (0.25–4.0)"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,3">
                              <TextBlock Text="Bordure :" FontSize="9"
                                         Foreground="{StaticResource Fg2}"
                                         VerticalAlignment="Center" Margin="0,0,4,0"/>
                              <TextBox Text="{Binding MediaBorderPx, UpdateSourceTrigger=PropertyChanged}"
                                       Width="28" FontSize="9" Padding="2,1"
                                       ToolTip="Épaisseur bordure (px)"/>
                              <TextBlock Text="px" FontSize="9"
                                         Foreground="{StaticResource Fg2}"
                                         VerticalAlignment="Center" Margin="2,0,8,0"/>
                              <TextBlock Text="Ombre :" FontSize="9"
                                         Foreground="{StaticResource Fg2}"
                                         VerticalAlignment="Center" Margin="0,0,4,0"/>
                              <TextBox Text="{Binding MediaShadowBlur, UpdateSourceTrigger=PropertyChanged}"
                                       Width="28" FontSize="9" Padding="2,1"
                                       ToolTip="Rayon blur ombre (px)"/>
                              <TextBlock Text="α" FontSize="9"
                                         Foreground="{StaticResource Fg2}"
                                         VerticalAlignment="Center" Margin="4,0,4,0"/>
                              <TextBox Text="{Binding MediaShadowAlpha, UpdateSourceTrigger=PropertyChanged}"
                                       Width="32" FontSize="9" Padding="2,1"
                                       ToolTip="Opacité ombre (0–1)"/>
                            </StackPanel>
                            <CheckBox Content="Boucler" FontSize="9"
                                      IsChecked="{Binding MediaLoop}"
                                      Margin="0,0,0,0"/>
                          </StackPanel>
                        </StackPanel>
                      </Border>

                    </StackPanel>
                  </Grid>
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </ScrollViewer>
      </Grid>

      <Border Grid.Column="3" Background="{StaticResource Line}"/>

      <Grid Grid.Column="4">
        <Grid.RowDefinitions>
          <RowDefinition Height="38"/>
          <RowDefinition Height="1"/>
          <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource Bg2}" Padding="10,0">
          <TextBlock Text="APERÇU" Style="{StaticResource SecLbl}" VerticalAlignment="Center"/>
        </Border>
        <Border Grid.Row="1" Background="{StaticResource Line}"/>

        <DockPanel Grid.Row="2" Background="{StaticResource Bg2}" LastChildFill="False">

          <Border DockPanel.Dock="Top"
                  Margin="12,12,12,0"
                  Background="#0D0D0F"
                  CornerRadius="6"
                  ClipToBounds="True"
                  Height="152">
            <Grid>
              <Image x:Name="PreviewImage"
                     Stretch="Uniform"
                     RenderOptions.BitmapScalingMode="HighQuality"/>
              <TextBlock x:Name="PreviewPlaceholder"
                         Text="Sélectionner un segment&#10;pour voir la slide"
                         TextAlignment="Center"
                         HorizontalAlignment="Center"
                         VerticalAlignment="Center"
                         Foreground="#444"
                         FontSize="12"
                         TextWrapping="Wrap"/>
            </Grid>
          </Border>

          <TextBlock x:Name="PreviewFileName"
                     DockPanel.Dock="Top"
                     Text="—"
                     Foreground="{StaticResource Fg2}"
                     FontSize="10" FontFamily="Consolas"
                     TextTrimming="CharacterEllipsis"
                     Margin="12,6,12,0"/>

          <Border DockPanel.Dock="Top" Height="1"
                  Background="{StaticResource Line}" Margin="0,12,0,12"/>

          <StackPanel DockPanel.Dock="Top" Margin="12,0,12,0"
                      x:Name="SegDetailPanel">

            <TextBlock Text="SEGMENT SÉLECTIONNÉ" Style="{StaticResource SecLbl}" Margin="0,0,0,10"/>

            <TextBlock Text="Chemin complet de la slide :"
                       Foreground="{StaticResource Fg2}" FontSize="10" Margin="0,0,0,4"/>
            <TextBox x:Name="SegSlidePathBox"
                     FontFamily="Consolas" FontSize="10"
                     TextChanged="OnSegSlidePathChanged"
                     ToolTip="Chemin relatif ou absolu vers la slide PNG/JPG"/>

            <TextBlock Text="Séquences assignées :"
                       Foreground="{StaticResource Fg2}" FontSize="10" Margin="0,12,0,4"/>
            <TextBlock x:Name="SegSeqCountLabel"
                       Text="0 séquence(s)"
                       Foreground="{StaticResource Fg}" FontSize="11"/>

            <TextBlock Text="Durée audio estimée :"
                       Foreground="{StaticResource Fg2}" FontSize="10" Margin="0,8,0,4"/>
            <TextBlock x:Name="SegDurationLabel"
                       Text="—"
                       Foreground="{StaticResource Fg}" FontSize="11"/>

          </StackPanel>

          <Border DockPanel.Dock="Top" Height="1"
                  Background="{StaticResource Line}" Margin="0,16,0,12"/>

          <StackPanel DockPanel.Dock="Top" Margin="12,0">
            <TextBlock Text="RÉSUMÉ MANIFEST" Style="{StaticResource SecLbl}" Margin="0,0,0,8"/>
            <TextBlock x:Name="SummaryLabel"
                       Text="0 segment(s) · 0 séquence(s)"
                       Foreground="{StaticResource Fg2}" FontSize="11"
                       TextWrapping="Wrap"/>
            <TextBlock x:Name="UnassignedLabel"
                       Text="0 séquence(s) non assignée(s)"
                       Foreground="#E84118" FontSize="11"
                       Margin="0,4,0,0"
                       TextWrapping="Wrap"/>
          </StackPanel>

        </DockPanel>
      </Grid>

    </Grid>

    <Border Grid.Row="3" Background="{StaticResource Line}"/>

    <Border Grid.Row="4" Background="{StaticResource Bg2}" Padding="12,0">
      <DockPanel LastChildFill="False" VerticalAlignment="Center">
        <TextBlock x:Name="StatusLabel"
                   Text="Glisser une séquence vers un segment pour l'assigner."
                   Foreground="{StaticResource Fg2}" FontSize="11"/>
        <TextBlock x:Name="ManifestPathLabel"
                   DockPanel.Dock="Right"
                   Foreground="{StaticResource Fg2}" FontSize="10"
                   FontFamily="Consolas"
                   TextTrimming="CharacterEllipsis"
                   MaxWidth="400"
                   Text="manifest non sauvegardé"/>
      </DockPanel>
    </Border>
  </Grid>
</Window>