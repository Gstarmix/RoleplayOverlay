<Window x:Class="RoleplayOverlay.SplitSequenceDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Diviser la séquence"
        Width="860" Height="580"
        MinWidth="640" MinHeight="400"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="#1A1A1F"
        Foreground="#E0E0E8">

  <Window.Resources>

    <SolidColorBrush x:Key="Bg"        Color="#1A1A1F"/>
    <SolidColorBrush x:Key="Bg2"       Color="#222228"/>
    <SolidColorBrush x:Key="Bg3"       Color="#2A2A32"/>
    <SolidColorBrush x:Key="Line"      Color="#3A3A44"/>
    <SolidColorBrush x:Key="Fg"        Color="#E0E0E8"/>
    <SolidColorBrush x:Key="Fg2"       Color="#9090A0"/>
    <SolidColorBrush x:Key="AccentEN"  Color="#2060C0"/>
    <SolidColorBrush x:Key="AccentFR"  Color="#1E8A3C"/>
    <SolidColorBrush x:Key="SepColor"  Color="#44454F"/>

    <Style x:Key="Btn" TargetType="Button">
      <Setter Property="Background"   Value="#2A2A32"/>
      <Setter Property="Foreground"   Value="#E0E0E8"/>
      <Setter Property="BorderBrush"  Value="#3A3A44"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="Padding"      Value="14,6"/>
      <Setter Property="FontSize"     Value="12"/>
      <Setter Property="Cursor"       Value="Hand"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="4" Padding="{TemplateBinding Padding}">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#383848"/>
              </Trigger>
              <Trigger Property="IsPressed" Value="True">
                <Setter Property="Background" Value="#202028"/>
              </Trigger>
              <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Opacity" Value="0.4"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style x:Key="BtnAccent" TargetType="Button" BasedOn="{StaticResource Btn}">
      <Setter Property="Background"  Value="#1E5FA8"/>
      <Setter Property="BorderBrush" Value="#2E7FD8"/>
      <Setter Property="FontWeight"  Value="SemiBold"/>
      <Style.Triggers>
        <Trigger Property="IsMouseOver" Value="True">
          <Setter Property="Background" Value="#2870C0"/>
        </Trigger>
      </Style.Triggers>
    </Style>

    <Style x:Key="BtnCut" TargetType="Button" BasedOn="{StaticResource Btn}">
      <Setter Property="Background"  Value="#2A2A32"/>
      <Setter Property="BorderBrush" Value="#555560"/>
      <Setter Property="Padding"     Value="10,5"/>
      <Setter Property="FontSize"    Value="11"/>
    </Style>

    <Style x:Key="EditorBox" TargetType="TextBox">
      <Setter Property="Background"          Value="#13131A"/>
      <Setter Property="Foreground"          Value="#E0E0E8"/>
      <Setter Property="BorderBrush"         Value="#3A3A44"/>
      <Setter Property="BorderThickness"     Value="1"/>
      <Setter Property="Padding"             Value="8"/>
      <Setter Property="FontFamily"          Value="Consolas, Courier New"/>
      <Setter Property="FontSize"            Value="12"/>
      <Setter Property="AcceptsReturn"       Value="True"/>
      <Setter Property="TextWrapping"        Value="Wrap"/>
      <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
      <Setter Property="CaretBrush"          Value="#E0E0E8"/>
      <Setter Property="SelectionBrush"      Value="#3060A0"/>
    </Style>
  </Window.Resources>

  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="48"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <Border Grid.Row="0" Background="#222228" Padding="16,0">
      <DockPanel VerticalAlignment="Center">
        <TextBlock Text="✂ Diviser la séquence" FontSize="14" FontWeight="SemiBold"
                   Foreground="#E0E0E8" VerticalAlignment="Center"/>
        <TextBlock x:Name="PairIdLabel" Foreground="#9090A0" FontSize="12"
                   Margin="10,0,0,0" VerticalAlignment="Center"/>
        <TextBlock DockPanel.Dock="Right" Foreground="#9090A0" FontSize="11"
                   VerticalAlignment="Center" HorizontalAlignment="Right"
                   Text="Placez le curseur dans le texte et cliquez « Couper ici »"/>
      </DockPanel>
    </Border>
    <Border Grid.Row="0" BorderBrush="#3A3A44" BorderThickness="0,0,0,1" VerticalAlignment="Bottom"/>

    <Grid Grid.Row="1" Margin="12,10,12,6">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="8"/>
        <ColumnDefinition Width="*"/>
      </Grid.ColumnDefinitions>

      <Grid Grid.Column="0">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="*"/>
          <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#1C2A3A" CornerRadius="4,4,0,0" Padding="10,6" Margin="0,0,0,1">
          <DockPanel>
            <Border Background="#2060C0" CornerRadius="3" Padding="6,2" Margin="0,0,8,0">
              <TextBlock Text="EN" FontSize="10" FontWeight="Bold" Foreground="White"/>
            </Border>
            <TextBlock x:Name="EnSpeakerLabel" Foreground="#9090A0" FontSize="11" VerticalAlignment="Center"/>
            <TextBlock x:Name="EnFragCountLabel" DockPanel.Dock="Right" Foreground="#6090C0"
                       FontSize="11" VerticalAlignment="Center" HorizontalAlignment="Right"/>
          </DockPanel>
        </Border>

        <TextBox x:Name="EnBox" Grid.Row="1" Style="{StaticResource EditorBox}"
                 GotFocus="OnEnBoxGotFocus" TextChanged="OnTextChanged"/>

        <Button Grid.Row="2" Content="✂ Couper ici (EN)" Style="{StaticResource BtnCut}"
                Margin="0,4,0,0" Click="OnCutHereEn"
                ToolTip="Insère un séparateur à la position du curseur dans le texte EN"/>
      </Grid>

      <Border Grid.Column="1" Background="#2A2A32" CornerRadius="2" Margin="0,24,0,32"/>

      <Grid Grid.Column="2">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="*"/>
          <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#1A2E1F" CornerRadius="4,4,0,0" Padding="10,6" Margin="0,0,0,1">
          <DockPanel>
            <Border Background="#1E8A3C" CornerRadius="3" Padding="6,2" Margin="0,0,8,0">
              <TextBlock Text="FR" FontSize="10" FontWeight="Bold" Foreground="White"/>
            </Border>
            <TextBlock x:Name="FrSpeakerLabel" Foreground="#9090A0" FontSize="11" VerticalAlignment="Center"/>
            <TextBlock x:Name="FrFragCountLabel" DockPanel.Dock="Right" Foreground="#30B060"
                       FontSize="11" VerticalAlignment="Center" HorizontalAlignment="Right"/>
          </DockPanel>
        </Border>

        <TextBox x:Name="FrBox" Grid.Row="1" Style="{StaticResource EditorBox}"
                 GotFocus="OnFrBoxGotFocus" TextChanged="OnTextChanged"/>

        <Button Grid.Row="2" Content="✂ Couper ici (FR)" Style="{StaticResource BtnCut}"
                Margin="0,4,0,0" Click="OnCutHereFr"
                ToolTip="Insère un séparateur à la position du curseur dans le texte FR"/>
      </Grid>
    </Grid>

    <Border Grid.Row="2" Background="#222228" BorderBrush="#3A3A44" BorderThickness="0,1,0,0" Padding="14,10">
      <DockPanel>

        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
          <Button Content="Annuler" Style="{StaticResource Btn}" Margin="0,0,8,0" Click="OnCancel" IsCancel="True"/>
          <Button x:Name="BtnValidate" Content="✓ Valider" Style="{StaticResource BtnAccent}"
                  Click="OnValidate" IsDefault="True"/>
        </StackPanel>

        <StackPanel Orientation="Vertical" VerticalAlignment="Center">
          <TextBlock x:Name="SummaryLabel" Foreground="#E0E0E8" FontSize="12" FontWeight="SemiBold"/>
          <TextBlock x:Name="WarningLabel" Foreground="#E8A317" FontSize="11" Margin="0,2,0,0" Visibility="Collapsed"/>
        </StackPanel>
      </DockPanel>
    </Border>
  </Grid>
</Window>