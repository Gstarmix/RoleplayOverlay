                  <Button Content="🎬" FontSize="10" Style="{StaticResource IconButton}" Padding="5,2" Click="OnComposedClipBrowse" ToolTip="Associer un clip déjà composé (dossier FaceCam\Composed, mode 'fond diapo' du Studio) à cette séquence : utilisé tel quel, pas de PiP à recomposer"/>
                  <Button Content="✕" FontSize="10" Style="{StaticResource IconButton}" Padding="5,2" Click="OnComposedClipClear" ToolTip="Retirer le clip composé de cette séquence"/></StackPanel>
                <TextBlock x:Name="ComposedClipLabel" Text="aucun" FontSize="9" Foreground="#888" VerticalAlignment="Center" Margin="8,0,0,0" TextTrimming="CharacterEllipsis"/></DockPanel>
              <Button x:Name="TimelineBtn" Content="🎞 Montage (timeline)" Style="{StaticResource DarkButton}"
                      Margin="0,0,0,6" HorizontalAlignment="Left" Padding="8,3" Click="OnOpenTimeline"
                      ToolTip="Placer des images/gameplay sur le clip composé : quand elles apparaissent, combien de temps, et où (façon CapCut)"/>

              <Border x:Name="PreviewBorder" Background="#0D0D0F" CornerRadius="5" ClipToBounds="True" Height="120" Margin="0,0,0,4"
                      MouseLeftButtonDown="OnPreviewThumbClick">
                <Border.ContextMenu>
                  <ContextMenu>
                    <MenuItem Header="— Fichier courant (copie projet) —" IsEnabled="False" FontWeight="SemiBold"/>
                    <MenuItem Header="👁 Ouvrir le fichier courant" Click="OnMediaCtxOpenCurrent"/>
                    <MenuItem Header="🗂 Localiser dans l'explorateur" Click="OnMediaCtxShowInExplorer"/>
