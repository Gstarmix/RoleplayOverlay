                <TextBlock Text="Medias" FontSize="10" FontWeight="SemiBold" Foreground="{StaticResource Fg}" DockPanel.Dock="Left" VerticalAlignment="Center"/>
                <TextBlock x:Name="MediaItemCountLabel" Text="" FontSize="9" Foreground="{StaticResource Fg2}" DockPanel.Dock="Left" VerticalAlignment="Center" Margin="6,0,0,0"/>
