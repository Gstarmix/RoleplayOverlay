<Window x:Class="RoleplayOverlay.EditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        xmlns:local="clr-namespace:RoleplayOverlay"
        Title="RoleplayOverlay — Studio" Height="780" MinHeight="560"
        Width="1200" MinWidth="820" ResizeMode="CanResize"
        WindowStartupLocation="CenterScreen"
        Icon="pack://application:,,,/Assets/scene.ico" Background="#0B0B0C">
  <Window.Resources>
    <SolidColorBrush x:Key="Bg" Color="#0B0B0C"/><SolidColorBrush x:Key="Bg2" Color="#141416"/>
    <SolidColorBrush x:Key="Bg3" Color="#1C1D20"/><SolidColorBrush x:Key="Line" Color="#2A2B2E"/>
    <SolidColorBrush x:Key="Fg" Color="#EAEAEA"/><SolidColorBrush x:Key="Fg2" Color="#9A9A9A"/>
    <SolidColorBrush x:Key="Accent" Color="#E84118"/><SolidColorBrush x:Key="AccentDim" Color="#7C1A0E"/>
    <SolidColorBrush x:Key="YouColor" Color="#FFD400"/><SolidColorBrush x:Key="Bot1Color" Color="#FF00FF"/>
    <SolidColorBrush x:Key="Bot2Color" Color="#00FFFF"/>
    <SolidColorBrush x:Key="LangEN" Color="#4DC93C"/><SolidColorBrush x:Key="LangFR" Color="#4D9BC9"/>
    <Style x:Key="DarkButton" TargetType="Button">
      <Setter Property="Foreground" Value="{StaticResource Fg}"/><Setter Property="Background" Value="{StaticResource Bg3}"/>
      <Setter Property="BorderBrush" Value="{StaticResource Line}"/><Setter Property="BorderThickness" Value="1"/>
      <Setter Property="Padding" Value="12,6"/><Setter Property="Cursor" Value="Hand"/><Setter Property="SnapsToDevicePixels" Value="True"/>
      <Setter Property="Template"><Setter.Value><ControlTemplate TargetType="Button">
        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="6" Padding="{TemplateBinding Padding}">
          <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/></Border>
        <ControlTemplate.Triggers>
          <Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="#252628"/></Trigger>
          <Trigger Property="IsPressed" Value="True"><Setter Property="Background" Value="#2C2D30"/></Trigger>
          <Trigger Property="IsEnabled" Value="False"><Setter Property="Opacity" Value="0.4"/></Trigger>
        </ControlTemplate.Triggers></ControlTemplate></Setter.Value></Setter></Style>
    <Style x:Key="AccentButton" TargetType="Button" BasedOn="{StaticResource DarkButton}">
      <Setter Property="Background" Value="{StaticResource Accent}"/><Setter Property="BorderBrush" Value="{StaticResource AccentDim}"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Style.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="#FF5733"/></Trigger>
        <Trigger Property="IsPressed" Value="True"><Setter Property="Background" Value="#C0391B"/></Trigger></Style.Triggers></Style>
    <Style x:Key="IconButton" TargetType="Button" BasedOn="{StaticResource DarkButton}">
      <Setter Property="Padding" Value="8,4"/><Setter Property="FontSize" Value="13"/><Setter Property="MinWidth" Value="30"/></Style>
    <Style TargetType="TextBox">
      <Setter Property="Foreground" Value="{StaticResource Fg}"/><Setter Property="Background" Value="#111113"/>
      <Setter Property="BorderBrush" Value="{StaticResource Line}"/><Setter Property="BorderThickness" Value="1"/>
      <Setter Property="Padding" Value="8,5"/><Setter Property="CaretBrush" Value="{StaticResource Fg}"/>
      <Setter Property="SelectionBrush" Value="{StaticResource Accent}"/><Setter Property="VerticalContentAlignment" Value="Center"/>
      <Setter Property="SnapsToDevicePixels" Value="True"/>
      <Setter Property="Template"><Setter.Value><ControlTemplate TargetType="TextBox">
        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="5">
          <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"/></Border>
      </ControlTemplate></Setter.Value></Setter></Style>
    <Style TargetType="ComboBox">
      <Setter Property="Foreground" Value="{StaticResource Fg}"/><Setter Property="Background" Value="#111113"/>
      <Setter Property="BorderBrush" Value="{StaticResource Line}"/><Setter Property="BorderThickness" Value="1"/>
      <Setter Property="Padding" Value="8,4"/><Setter Property="HorizontalContentAlignment" Value="Left"/>
      <Setter Property="VerticalContentAlignment" Value="Center"/>
      <Setter Property="Template"><Setter.Value><ControlTemplate TargetType="ComboBox"><Grid>
        <Border x:Name="Border" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="5"><Grid>
          <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="20"/></Grid.ColumnDefinitions>
          <ContentPresenter Grid.Column="0" Margin="8,4,0,4" Content="{TemplateBinding SelectionBoxItem}"
            ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}" VerticalAlignment="Center" TextElement.Foreground="{StaticResource Fg}"/>
          <TextBlock Grid.Column="1" Text="▾" Foreground="{StaticResource Fg2}" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="10"/>
          <ToggleButton Grid.Column="0" Grid.ColumnSpan="2" Focusable="False"
            IsChecked="{Binding IsDropDownOpen,RelativeSource={RelativeSource TemplatedParent},Mode=TwoWay}">
            <ToggleButton.Style><Style TargetType="ToggleButton"><Setter Property="Background" Value="Transparent"/>
              <Setter Property="BorderThickness" Value="0"/><Setter Property="Template"><Setter.Value>
              <ControlTemplate TargetType="ToggleButton"><Border Background="Transparent"/></ControlTemplate>
            </Setter.Value></Setter></Style></ToggleButton.Style></ToggleButton></Grid></Border>
        <Popup x:Name="PART_Popup" IsOpen="{TemplateBinding IsDropDownOpen}" AllowsTransparency="True" Focusable="False"
               PopupAnimation="Slide" Placement="Bottom">
          <Border Background="#1C1D20" BorderBrush="{StaticResource Line}" BorderThickness="1"
                  MaxHeight="{TemplateBinding MaxDropDownHeight}"><ScrollViewer><ItemsPresenter/></ScrollViewer></Border>
        </Popup></Grid></ControlTemplate></Setter.Value></Setter></Style>
    <Style TargetType="ComboBoxItem">
      <Setter Property="Foreground" Value="{StaticResource Fg}"/><Setter Property="Background" Value="#141416"/>
      <Setter Property="Padding" Value="10,6"/><Setter Property="FontSize" Value="12"/><Setter Property="Cursor" Value="Hand"/>
      <Setter Property="Template"><Setter.Value><ControlTemplate TargetType="ComboBoxItem">
        <Border x:Name="Bd" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
          <ContentPresenter VerticalAlignment="Center"/></Border>
        <ControlTemplate.Triggers>
          <Trigger Property="IsHighlighted" Value="True"><Setter TargetName="Bd" Property="Background" Value="#14FFFFFF"/>
            <Setter TargetName="Bd" Property="BorderThickness" Value="2,0,0,0"/><Setter TargetName="Bd" Property="BorderBrush" Value="#60E84118"/></Trigger>
          <Trigger Property="IsSelected" Value="True"><Setter TargetName="Bd" Property="Background" Value="#1AE84118"/>
            <Setter TargetName="Bd" Property="BorderThickness" Value="2,0,0,0"/><Setter TargetName="Bd" Property="BorderBrush" Value="#E84118"/>
            <Setter Property="Foreground" Value="White"/></Trigger>
        </ControlTemplate.Triggers></ControlTemplate></Setter.Value></Setter></Style>
    <Style TargetType="CheckBox"><Setter Property="Foreground" Value="{StaticResource Fg2}"/>
      <Setter Property="VerticalContentAlignment" Value="Center"/></Style>
    <Style x:Key="SectionLabel" TargetType="TextBlock"><Setter Property="Foreground" Value="{StaticResource Fg2}"/>
      <Setter Property="FontSize" Value="10"/><Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="Margin" Value="0,0,0,6"/><Setter Property="Text" Value="SECTION"/></Style>
    <Style TargetType="DataGrid"><Setter Property="Background" Value="Transparent"/><Setter Property="Foreground" Value="{StaticResource Fg}"/>
      <Setter Property="BorderThickness" Value="0"/><Setter Property="GridLinesVisibility" Value="Horizontal"/>
      <Setter Property="HorizontalGridLinesBrush" Value="{StaticResource Line}"/><Setter Property="RowBackground" Value="Transparent"/>
      <Setter Property="AlternatingRowBackground" Value="Transparent"/><Setter Property="ColumnHeaderHeight" Value="32"/></Style>
    <Style TargetType="DataGridColumnHeader"><Setter Property="Background" Value="{StaticResource Bg2}"/>
      <Setter Property="Foreground" Value="{StaticResource Fg2}"/><Setter Property="FontSize" Value="10"/>
      <Setter Property="FontWeight" Value="SemiBold"/><Setter Property="Padding" Value="8,0"/>
      <Setter Property="BorderBrush" Value="{StaticResource Line}"/><Setter Property="BorderThickness" Value="0,0,1,1"/></Style>
    <Style TargetType="DataGridRow">

      <Setter Property="Background" Value="{Binding Speaker, Converter={x:Static local:SpeakerToBrushConverter.Instance}}"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Style.Triggers>
        <Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="#14FFFFFF"/></Trigger>
        <Trigger Property="IsSelected" Value="True">
          <Setter Property="Background" Value="#88E84118"/>
          <Setter Property="BorderBrush" Value="#E84118"/>
          <Setter Property="BorderThickness" Value="3,0,0,0"/>
        </Trigger>
      </Style.Triggers></Style>
    <Style TargetType="DataGridCell"><Setter Property="Background" Value="Transparent"/><Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Padding" Value="6,0"/><Setter Property="Foreground" Value="{StaticResource Fg}"/>
      <Style.Triggers><Trigger Property="IsSelected" Value="True"><Setter Property="Background" Value="#88E84118"/><Setter Property="Foreground" Value="{StaticResource Fg}"/></Trigger></Style.Triggers></Style>
    <Style x:Key="VSep" TargetType="Border"><Setter Property="Width" Value="1"/><Setter Property="Background" Value="{StaticResource Line}"/></Style>
  </Window.Resources>
  <Grid>
    <Grid.RowDefinitions><RowDefinition Height="48"/><RowDefinition Height="1"/><RowDefinition Height="*"/></Grid.RowDefinitions>
    <Border Grid.Row="0" Background="{StaticResource Bg2}"><DockPanel LastChildFill="False" Margin="12,0">
      <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center">
        <TextBlock Text="🎬" FontSize="18" VerticalAlignment="Center" Margin="0,0,10,0"/>
        <TextBlock Text="STUDIO" FontSize="11" FontWeight="Bold" Foreground="{StaticResource Fg}" VerticalAlignment="Center"/>
        <Border Width="1" Background="{StaticResource Line}" Margin="14,8"/>
        <TextBox x:Name="PathBox" Width="340" Margin="0,0,8,0" VerticalAlignment="Center" ToolTip="Chemin .json"/>
        <Button Content="📂 Ouvrir" Style="{StaticResource DarkButton}" Margin="0,0,6,0" Click="OnLoad"/>
        <Button Content="💾 Sauvegarder" Style="{StaticResource DarkButton}" Click="OnSave"/>
        <Button Content="📄 Importer PDF" Style="{StaticResource DarkButton}" Margin="6,0,0,0"
                Click="OnImportPdf"
                ToolTip="Convertir un PDF ou ZIP en slides PNG (slide_001.png, slide_002.png, …)"/>
        <Button Content="🎙 Voix off" Style="{StaticResource DarkButton}" Margin="6,0,0,0"
                Click="OnGenerateVoiceFromScript"
                ToolTip="Choisir un script texte et générer un fichier audio (SAPI par défaut, Azure si configuré)"/>
        <Button Content="📷 Caméra" Style="{StaticResource DarkButton}" Margin="6,0,0,0"
                Click="OnOpenCamStudio"
                ToolTip="Studio caméra : face-cam (filtres façon NVIDIA Broadcast) + téléprompteur + enregistrement, dans RoleplayOverlay"/>
        <Button Content="🎬 Importer clips" Style="{StaticResource DarkButton}" Margin="6,0,0,0"
                Click="OnImportComposedClips"
                ToolTip="Choisir plusieurs clips composés (FaceCam\Composed) : crée une ligne par clip, dans l'ordre du nom, en français"/>
        <TextBlock x:Name="SaveIndicator" Text="✓" FontSize="14" FontWeight="Bold"
                   Foreground="#4DC93C" VerticalAlignment="Center" Margin="10,0,0,0"
                   ToolTip="Projet sauvegardé" Opacity="0.7"/>
      </StackPanel>
      <Border DockPanel.Dock="Right" Width="1" Background="{StaticResource Line}" Margin="14,8"/>
      <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,14,0">
        <TextBlock Text="Bulles :" Foreground="{StaticResource Fg2}" FontSize="11" VerticalAlignment="Center" Margin="0,0,10,0"/>
        <CheckBox x:Name="ShowYouCheck" Content="Vous" IsChecked="False" Margin="0,0,10,0" Checked="OnBubbleVisibilityChanged" Unchecked="OnBubbleVisibilityChanged"/>
        <CheckBox x:Name="ShowBot1Check" Content="Bot 1" IsChecked="False" Margin="0,0,10,0" Checked="OnBubbleVisibilityChanged" Unchecked="OnBubbleVisibilityChanged"/>
        <CheckBox x:Name="ShowBot2Check" Content="Bot 2" IsChecked="False" Checked="OnBubbleVisibilityChanged" Unchecked="OnBubbleVisibilityChanged"/>
      </StackPanel></DockPanel></Border>
    <Border Grid.Row="1" Background="{StaticResource Line}"/>
    <Grid Grid.Row="2">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="200" MinWidth="160"/><ColumnDefinition Width="1"/>
        <ColumnDefinition Width="*" MinWidth="400"/><ColumnDefinition Width="1"/>
        <ColumnDefinition Width="320" MinWidth="280"/>
      </Grid.ColumnDefinitions>
      <DockPanel Grid.Column="0" Background="{StaticResource Bg2}" LastChildFill="True">

        <Border DockPanel.Dock="Top" BorderBrush="{StaticResource Line}" BorderThickness="0,0,0,1" Padding="10,8">
          <DockPanel>
            <TextBlock Text="SCÈNES" Style="{StaticResource SectionLabel}" VerticalAlignment="Center" Margin="0"/>
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
              <Button Content="✏" Style="{StaticResource IconButton}" Padding="6,3" FontSize="11"
                      Click="OnRenameScene"    ToolTip="Renommer la scène (ou double-clic sur le nom)"/>
              <Button Content="⧉" Style="{StaticResource IconButton}" Padding="6,3" FontSize="11"
                      Click="OnDuplicateScene" ToolTip="Dupliquer la scène sélectionnée"/>
              <Button Content="✕" Style="{StaticResource IconButton}" Padding="6,3" FontSize="11"
                      Click="OnDeleteScene"    ToolTip="Supprimer la scène sélectionnée"/>
              <Button Content="+" Style="{StaticResource IconButton}" Padding="6,3" FontSize="11"
                      Click="OnAddScene"       ToolTip="Nouvelle scène"/>
            </StackPanel>
          </DockPanel>
        </Border>

        <ListBox x:Name="SceneList" DockPanel.Dock="Top"
                 MaxHeight="220" MinHeight="60"
                 Background="Transparent" BorderThickness="0"
                 Foreground="{StaticResource Fg}"
                 SelectionChanged="OnSceneSelected"
                 AllowDrop="True"
                 PreviewMouseLeftButtonDown="OnSceneListPreviewMouseDown"
                 PreviewMouseMove="OnSceneListMouseMove"
                 DragOver="OnSceneListDragOver"
                 Drop="OnSceneListDrop"
                 VirtualizingPanel.ScrollUnit="Pixel"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                 ScrollViewer.VerticalScrollBarVisibility="Auto">

          <ListBox.Resources>
            <Style x:Key="SceneScrollThumb" TargetType="Thumb">
              <Setter Property="Template">
                <Setter.Value>
                  <ControlTemplate TargetType="Thumb">
                    <Border Background="#55FFFFFF" CornerRadius="2" Margin="1,2"/>
                    <ControlTemplate.Triggers>
                      <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="#99FFFFFF"/>
                      </Trigger>
                      <Trigger Property="IsDragging" Value="True">
                        <Setter Property="Background" Value="#CCFFFFFF"/>
                      </Trigger>
                    </ControlTemplate.Triggers>
                  </ControlTemplate>
                </Setter.Value>
              </Setter>
            </Style>

            <Style TargetType="ScrollBar">
              <Setter Property="Width" Value="5"/>
              <Setter Property="MinWidth" Value="5"/>
              <Setter Property="Background" Value="Transparent"/>
              <Setter Property="Template">
                <Setter.Value>
                  <ControlTemplate TargetType="ScrollBar">
                    <Grid Background="Transparent" Width="5">
                      <RepeatButton x:Name="PART_LineUpButton"
                                    Height="0" Command="ScrollBar.LineUpCommand"
                                    Opacity="0" Focusable="False"/>
                      <Track x:Name="PART_Track" IsDirectionReversed="True">
                        <Track.DecreaseRepeatButton>
                          <RepeatButton Command="ScrollBar.PageUpCommand"
                                        Background="Transparent" BorderThickness="0"
                                        Opacity="0" Focusable="False"/>
                        </Track.DecreaseRepeatButton>
                        <Track.Thumb>
                          <Thumb Style="{StaticResource SceneScrollThumb}"/>
                        </Track.Thumb>
                        <Track.IncreaseRepeatButton>
                          <RepeatButton Command="ScrollBar.PageDownCommand"
                                        Background="Transparent" BorderThickness="0"
                                        Opacity="0" Focusable="False"/>
                        </Track.IncreaseRepeatButton>
                      </Track>
                      <RepeatButton x:Name="PART_LineDownButton"
                                    Height="0" Command="ScrollBar.LineDownCommand"
                                    Opacity="0" Focusable="False" VerticalAlignment="Bottom"/>
                    </Grid>
                  </ControlTemplate>
                </Setter.Value>
              </Setter>
            </Style>
          </ListBox.Resources>

          <ListBox.ItemTemplate>
            <DataTemplate DataType="{x:Type local:EditorWindow+SceneDisplayItem}">
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="16"/>
                  <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="{Binding SlideIcon}"
                           Foreground="{Binding SlideColor}"
                           FontSize="10" FontWeight="Bold"
                           VerticalAlignment="Center"
                           ToolTip="{Binding SlideTooltip}"
                           Margin="0,0,4,0"/>

                <TextBlock Grid.Column="1"
                           Text="{Binding Name}"
                           VerticalAlignment="Center"
                           FontSize="11"
                           TextTrimming="CharacterEllipsis"
                           ToolTip="{Binding Name}"
                           MouseLeftButtonDown="OnSceneNameDoubleClick"/>
              </Grid>
            </DataTemplate>
          </ListBox.ItemTemplate>

          <ListBox.ItemContainerStyle>
            <Style TargetType="ListBoxItem">
              <Setter Property="Background" Value="Transparent"/>
              <Setter Property="Foreground" Value="{StaticResource Fg}"/>
              <Setter Property="Padding" Value="8,5"/>
              <Setter Property="AllowDrop" Value="True"/>
              <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
              <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                  <Setter Property="Background" Value="#88E84118"/>
                  <Setter Property="BorderBrush" Value="#E84118"/>
                  <Setter Property="BorderThickness" Value="3,0,0,0"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                  <Setter Property="Background" Value="#12FFFFFF"/>
                </Trigger>
              </Style.Triggers>
            </Style>
          </ListBox.ItemContainerStyle>
        </ListBox>

        <Border DockPanel.Dock="Top" Height="1" Background="{StaticResource Line}"/>

        <StackPanel DockPanel.Dock="Top" Margin="10,10,10,0">
          <TextBlock Text="MONITEUR" Style="{StaticResource SectionLabel}"/>
          <ComboBox x:Name="DisplayBox" Margin="0,0,0,6" SelectionChanged="OnMonitorChanged"/>
          <StackPanel Orientation="Horizontal">
            <Button Content="↻" Style="{StaticResource IconButton}" Margin="0,0,6,0" Click="OnRefreshMonitors" ToolTip="Actualiser la liste des écrans"/>
            <Button Content="Appliquer" Style="{StaticResource IconButton}" Click="OnApplyMonitor"/>
          </StackPanel>
        </StackPanel>

        <Border DockPanel.Dock="Top" Height="1" Background="{StaticResource Line}" Margin="0,12,0,0"/>

        <StackPanel DockPanel.Dock="Top" Margin="10,10,10,0">
          <TextBlock Text="VOIX TTS" Style="{StaticResource SectionLabel}"/>
          <Grid Margin="0,0,0,6">
            <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="6"/><ColumnDefinition/></Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
              <TextBlock Text="Bot 1" FontSize="9" FontWeight="SemiBold" Foreground="#FF00FF" Margin="0,0,0,3"/>
              <ComboBox x:Name="Bot1VoiceBox" FontSize="10" SelectionChanged="OnQuickVoiceChanged">
                <ComboBoxItem Content="en-US" Tag="en-US"/>
                <ComboBoxItem Content="en-GB" Tag="en-GB"/>
                <ComboBoxItem Content="en-AU" Tag="en-AU"/>
                <ComboBoxItem Content="en-CA" Tag="en-CA"/>
              </ComboBox>
            </StackPanel>
            <StackPanel Grid.Column="2">
              <TextBlock Text="Bot 2" FontSize="9" FontWeight="SemiBold" Foreground="#00FFFF" Margin="0,0,0,3"/>
              <ComboBox x:Name="Bot2VoiceBox" FontSize="10" SelectionChanged="OnQuickVoiceChanged">
                <ComboBoxItem Content="fr-FR" Tag="fr-FR"/>
                <ComboBoxItem Content="fr-BE" Tag="fr-BE"/>
                <ComboBoxItem Content="fr-CA" Tag="fr-CA"/>
              </ComboBox>
            </StackPanel>
          </Grid>
          <Button Content="↻ Appliquer à toutes" Style="{StaticResource IconButton}"
                  HorizontalAlignment="Stretch" FontSize="9" Padding="4,4"
                  Click="OnApplyVoiceToAll"
                  ToolTip="Applique la voix Bot1/Bot2 à toutes les séquences correspondantes"/>
          <TextBlock Text="You → ignoré" FontSize="9" Foreground="{StaticResource Fg2}" Margin="0,4,0,0"/>
        </StackPanel>

        <Border DockPanel.Dock="Top" Height="1" Background="{StaticResource Line}" Margin="0,12,0,0"/>

        <StackPanel DockPanel.Dock="Bottom" Margin="10,10">
          <TextBlock x:Name="StatsBlock"  Text="0 séquences" Foreground="{StaticResource Fg2}" FontSize="10"/>
          <TextBlock x:Name="StatsDur"    Text=""            Foreground="{StaticResource Fg2}" FontSize="10" Margin="0,2,0,0"/>
          <TextBlock x:Name="StatsMedia"  Text=""            Foreground="{StaticResource Fg2}" FontSize="10" Margin="0,2,0,0"/>
        </StackPanel>

        <Border Background="Transparent"/>
      </DockPanel>
      <Border Grid.Column="1" Style="{StaticResource VSep}"/>
      <Grid Grid.Column="2">
        <Grid.RowDefinitions><RowDefinition Height="42"/><RowDefinition Height="1"/><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>

        <Border x:Name="SearchBar" Grid.Row="2" Background="#1A1A1D" BorderBrush="{StaticResource Line}"
                BorderThickness="0,0,0,1" Padding="8,6" Visibility="Visible">
          <Grid>
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto"/>
              <RowDefinition x:Name="ReplaceRow" Height="Auto"/>
            </Grid.RowDefinitions>

            <DockPanel Grid.Row="0">
              <Button DockPanel.Dock="Right" Content="X" FontSize="12" Padding="6,2" Margin="4,0,0,0"
                      Style="{StaticResource IconButton}" Click="OnSearchClose" ToolTip="Fermer (Esc)"/>
              <Button x:Name="BtnToggleReplace" Content="&#x21C4;" FontSize="13" Padding="6,2" Margin="4,0,0,0"
                      Style="{StaticResource IconButton}" Click="OnToggleReplace"
                      ToolTip="Afficher/masquer le remplacement (Ctrl+H)"/>
              <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Margin="6,0,0,0">
                <TextBlock x:Name="SearchCountLabel" Text="" Foreground="{StaticResource Fg2}"
                           FontSize="10" FontFamily="Consolas" VerticalAlignment="Center" MinWidth="50"
                           TextAlignment="Center"/>
                <Button Content="^" FontSize="10" Padding="6,2" Style="{StaticResource IconButton}"
                        Click="OnSearchPrev" ToolTip="Occurrence precedente (Shift+F3)"/>
                <Button Content="v" FontSize="10" Padding="6,2" Style="{StaticResource IconButton}"
                        Click="OnSearchNext" ToolTip="Occurrence suivante (F3)"/>
              </StackPanel>
              <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Margin="6,0,0,0">
                <CheckBox x:Name="SearchCaseCheck" Content="Aa" Foreground="{StaticResource Fg2}"
                          FontSize="10" VerticalAlignment="Center" Margin="0,0,4,0"
                          ToolTip="Sensible a la casse" Checked="OnSearchTermChanged" Unchecked="OnSearchTermChanged"/>
                <CheckBox x:Name="SearchFieldsCheck" Content="Tout" Foreground="{StaticResource Fg2}"
                          FontSize="10" VerticalAlignment="Center"
                          ToolTip="Chercher aussi dans Note/Speaker/Voice (sinon Texte seul)"
                          Checked="OnSearchTermChanged" Unchecked="OnSearchTermChanged"/>
              </StackPanel>
              <TextBox x:Name="SearchBox" Margin="0,0,4,0" FontSize="11" Padding="6,4"
                       Background="#111113" Foreground="{StaticResource Fg}"
                       BorderBrush="{StaticResource Line}" BorderThickness="1"
                       TextChanged="OnSearchTermChanged"
                       KeyDown="OnSearchBoxKeyDown"/>
            </DockPanel>

            <DockPanel x:Name="ReplacePanel" Grid.Row="1" Margin="0,6,0,0" Visibility="Collapsed">
              <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Margin="4,0,0,0">
                <Button Content="Remplacer" FontSize="10" Padding="8,3" Style="{StaticResource IconButton}"
                        Click="OnReplaceCurrent" ToolTip="Remplacer l'occurrence courante"/>
                <Button Content="Tout" FontSize="10" Padding="8,3" Style="{StaticResource IconButton}"
                        Click="OnReplaceAll" ToolTip="Remplacer toutes les occurrences"/>
              </StackPanel>
              <TextBox x:Name="ReplaceBox" Margin="0,0,4,0" FontSize="11" Padding="6,4"
                       Background="#111113" Foreground="{StaticResource Fg}"
                       BorderBrush="{StaticResource Line}" BorderThickness="1"
                       KeyDown="OnReplaceBoxKeyDown"/>
            </DockPanel>
          </Grid>
        </Border>
        <Border Grid.Row="0" Background="{StaticResource Bg2}" Padding="10,0">
          <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
            <Button Content="+ Ligne" Style="{StaticResource IconButton}" Click="OnAdd" ToolTip="Ins"/>
            <Button Content="✕ Suppr" Style="{StaticResource IconButton}" Click="OnRemove" ToolTip="Ctrl+Del"/>
            <Border Width="1" Background="{StaticResource Line}" Margin="4,8"/>
            <Button Content="▲" Style="{StaticResource IconButton}" Click="OnUp"/><Button Content="▼" Style="{StaticResource IconButton}" Click="OnDown"/>
            <Border Width="1" Background="{StaticResource Line}" Margin="4,8"/>
            <Button x:Name="BtnUndo" Content="↩" Style="{StaticResource IconButton}" Click="OnUndo" ToolTip="Annuler (Ctrl+Z)" IsEnabled="False"/>
            <Button x:Name="BtnRedo" Content="↪" Style="{StaticResource IconButton}" Click="OnRedo" ToolTip="Rétablir (Ctrl+Y)" IsEnabled="False"/>
            <Border Width="1" Background="{StaticResource Line}" Margin="4,8"/>
            <Button Content="▶ Jouer" Style="{StaticResource IconButton}" Click="OnPlaySelected"/>
            <Button Content="⏹ Stop" Style="{StaticResource IconButton}" Click="OnStop"/>
            <Border Width="1" Background="{StaticResource Line}" Margin="4,8"/>
