                  <TextBlock.Style><Style TargetType="TextBlock">
                    <Setter Property="Foreground" Value="{StaticResource Fg2}"/>
                    <Style.Triggers>
                      <DataTrigger Binding="{Binding DurationIsExact}" Value="True">
                        <Setter Property="Foreground" Value="{StaticResource LangEN}"/>
                      </DataTrigger>
                    </Style.Triggers>
                  </Style></TextBlock.Style>
                </TextBlock>
              </DataTemplate></DataGridTemplateColumn.CellTemplate>
            </DataGridTemplateColumn>

            <DataGridTemplateColumn Header="Spk" Width="50">
              <DataGridTemplateColumn.CellTemplate><DataTemplate>
                <Border CornerRadius="4" Padding="4,1" HorizontalAlignment="Center">
                  <Border.Style><Style TargetType="Border"><Style.Triggers>
                    <DataTrigger Binding="{Binding Speaker}" Value="you"><Setter Property="Background" Value="#33FFD400"/></DataTrigger>
                    <DataTrigger Binding="{Binding Speaker}" Value="bot1"><Setter Property="Background" Value="#22FF00FF"/></DataTrigger>
                    <DataTrigger Binding="{Binding Speaker}" Value="bot2"><Setter Property="Background" Value="#2200FFFF"/></DataTrigger>
                  </Style.Triggers></Style></Border.Style>
                  <TextBlock FontSize="10" FontWeight="SemiBold" HorizontalAlignment="Center"><TextBlock.Style><Style TargetType="TextBlock"><Style.Triggers>
                    <DataTrigger Binding="{Binding Speaker}" Value="you"><Setter Property="Text" Value="YOU"/><Setter Property="Foreground" Value="#FFD400"/></DataTrigger>
                    <DataTrigger Binding="{Binding Speaker}" Value="bot1"><Setter Property="Text" Value="B1"/><Setter Property="Foreground" Value="#FF00FF"/></DataTrigger>
                    <DataTrigger Binding="{Binding Speaker}" Value="bot2"><Setter Property="Text" Value="B2"/><Setter Property="Foreground" Value="#00FFFF"/></DataTrigger>
                    <DataTrigger Binding="{Binding Speaker}" Value="{x:Null}"><Setter Property="Text" Value="B1"/><Setter Property="Foreground" Value="#FF00FF"/></DataTrigger>
                  </Style.Triggers></Style></TextBlock.Style></TextBlock></Border>
              </DataTemplate></DataGridTemplateColumn.CellTemplate>
              <DataGridTemplateColumn.CellEditingTemplate><DataTemplate>
                <ComboBox SelectedItem="{Binding Speaker, UpdateSourceTrigger=PropertyChanged}" FontSize="11">
                  <sys:String>you</sys:String><sys:String>bot1</sys:String><sys:String>bot2</sys:String></ComboBox>
              </DataTemplate></DataGridTemplateColumn.CellEditingTemplate></DataGridTemplateColumn>
            <DataGridTemplateColumn Header="Lang" Width="56"><DataGridTemplateColumn.CellTemplate><DataTemplate>
              <TextBlock FontSize="10" FontWeight="SemiBold" HorizontalAlignment="Center"><TextBlock.Style><Style TargetType="TextBlock">
                <Setter Property="Text" Value="—"/><Setter Property="Foreground" Value="{StaticResource Fg2}"/><Style.Triggers>
                <DataTrigger Binding="{Binding Voice}" Value="en-US"><Setter Property="Text" Value="🇬🇧 EN"/><Setter Property="Foreground" Value="{StaticResource LangEN}"/></DataTrigger>
                <DataTrigger Binding="{Binding Voice}" Value="en-GB"><Setter Property="Text" Value="🇬🇧 EN"/><Setter Property="Foreground" Value="{StaticResource LangEN}"/></DataTrigger>
                <DataTrigger Binding="{Binding Voice}" Value="fr-FR"><Setter Property="Text" Value="🇫🇷 FR"/><Setter Property="Foreground" Value="{StaticResource LangFR}"/></DataTrigger>
              </Style.Triggers></Style></TextBlock.Style></TextBlock></DataTemplate></DataGridTemplateColumn.CellTemplate>
              <DataGridTemplateColumn.CellEditingTemplate><DataTemplate>
                <ComboBox SelectedItem="{Binding Voice, UpdateSourceTrigger=PropertyChanged}" FontSize="11">
                  <sys:String>fr-FR</sys:String><sys:String>en-US</sys:String></ComboBox></DataTemplate></DataGridTemplateColumn.CellEditingTemplate></DataGridTemplateColumn>
            <DataGridTemplateColumn Header="Mode" Width="60"><DataGridTemplateColumn.CellTemplate><DataTemplate>
              <Border CornerRadius="4" Padding="4,1" HorizontalAlignment="Center">
                <Border.Style><Style TargetType="Border"><Style.Triggers>
                  <DataTrigger Binding="{Binding Mode}" Value="mp3"><Setter Property="Background" Value="#22E84118"/></DataTrigger>
                  <DataTrigger Binding="{Binding Mode}" Value="tts"><Setter Property="Background" Value="#221A6B3C"/></DataTrigger>
                </Style.Triggers></Style></Border.Style>
                <TextBlock Text="{Binding Mode}" FontSize="10" FontWeight="SemiBold" HorizontalAlignment="Center"><TextBlock.Style><Style TargetType="TextBlock"><Style.Triggers>
                  <DataTrigger Binding="{Binding Mode}" Value="mp3"><Setter Property="Foreground" Value="#E84118"/></DataTrigger>
                  <DataTrigger Binding="{Binding Mode}" Value="tts"><Setter Property="Foreground" Value="#4DC93C"/></DataTrigger>
                </Style.Triggers></Style></TextBlock.Style></TextBlock></Border>
            </DataTemplate></DataGridTemplateColumn.CellTemplate>
              <DataGridTemplateColumn.CellEditingTemplate><DataTemplate>
                <ComboBox SelectedItem="{Binding Mode, UpdateSourceTrigger=PropertyChanged}" FontSize="11">
                  <sys:String>mp3</sys:String><sys:String>tts</sys:String></ComboBox></DataTemplate></DataGridTemplateColumn.CellEditingTemplate></DataGridTemplateColumn>
            <DataGridTemplateColumn Header="Clip" Width="42" IsReadOnly="True">
              <DataGridTemplateColumn.CellTemplate><DataTemplate>
                <TextBlock Text="{Binding ClipBadge}" ToolTip="{Binding ClipTooltip}"
                           HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="13"/>
              </DataTemplate></DataGridTemplateColumn.CellTemplate></DataGridTemplateColumn>
            <DataGridTextColumn Header="Note" Width="120" Binding="{Binding Note, UpdateSourceTrigger=PropertyChanged}">
              <DataGridTextColumn.ElementStyle><Style TargetType="TextBlock"><Setter Property="Foreground" Value="{StaticResource Fg2}"/>
                <Setter Property="FontSize" Value="11"/><Setter Property="Padding" Value="4,0"/><Setter Property="TextTrimming" Value="CharacterEllipsis"/></Style></DataGridTextColumn.ElementStyle></DataGridTextColumn>
            <DataGridTextColumn x:Name="TextCol" Header="Texte / Script" Width="3*"
                                Binding="{Binding Text, UpdateSourceTrigger=PropertyChanged}">
              <DataGridTextColumn.ElementStyle>
                <Style TargetType="TextBlock">
                  <Setter Property="Foreground" Value="{StaticResource Fg}"/>
                  <Setter Property="FontSize" Value="11"/>
                  <Setter Property="Padding" Value="6,0"/>
                  <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                  <Setter Property="VerticalAlignment" Value="Center"/>
                  <Setter Property="ToolTip" Value="{Binding Text}"/>
                </Style>
              </DataGridTextColumn.ElementStyle>
              <DataGridTextColumn.EditingElementStyle>
                <Style TargetType="TextBox">
                  <Setter Property="Foreground" Value="{StaticResource Fg}"/>
                  <Setter Property="FontSize" Value="11"/>
                  <Setter Property="Padding" Value="6,0"/>
                  <Setter Property="Background" Value="#0B0B0C"/>
                  <Setter Property="BorderThickness" Value="0"/>
                  <Setter Property="AcceptsReturn" Value="False"/>
                  <Setter Property="VerticalContentAlignment" Value="Center"/>
                </Style>
              </DataGridTextColumn.EditingElementStyle>
            </DataGridTextColumn>
            <DataGridTemplateColumn Header="" Width="36"><DataGridTemplateColumn.CellTemplate><DataTemplate>
              <Button Content="✏" Padding="2,0" Style="{StaticResource IconButton}" Tag="{Binding}" ToolTip="Éditeur plein écran" Click="OnEditTextClick" FontSize="12"/>
            </DataTemplate></DataGridTemplateColumn.CellTemplate></DataGridTemplateColumn>

            <DataGridTemplateColumn Header="Média" Width="92">
              <DataGridTemplateColumn.CellTemplate>
                <DataTemplate>
                  <Button Padding="2,3" Style="{StaticResource IconButton}" Tag="{Binding}"
                          Click="OnPickMediaClick" ToolTip="Clic = assigner · Clic droit = options">
                    <Button.ContextMenu>
                      <ContextMenu>
                        <MenuItem Header="— Fichier courant (copie projet) —" IsEnabled="False" FontWeight="SemiBold"/>
                        <MenuItem Header="👁 Ouvrir le fichier courant" Tag="{Binding}" Click="OnGridMediaCtxOpenCurrent"/>
                        <MenuItem Header="🗂 Localiser dans l'explorateur" Tag="{Binding}" Click="OnGridMediaCtxShowInExplorer"/>
                        <MenuItem Header="⧉ Copier le chemin courant" Tag="{Binding}" Click="OnGridMediaCtxCopyPath"/>
                        <Separator/>
                        <MenuItem Header="— Source originale —" IsEnabled="False" FontWeight="SemiBold"/>
                        <MenuItem Header="👁 Ouvrir la source originale" Tag="{Binding}" Click="OnGridMediaCtxViewSource"/>
                        <MenuItem Header="🗂 Source dans l'explorateur" Tag="{Binding}" Click="OnGridMediaCtxSourceInExplorer"/>
                        <MenuItem Header="⧉ Copier le chemin source" Tag="{Binding}" Click="OnGridMediaCtxCopySourcePath"/>
                        <Separator/>
                        <MenuItem Header="🔄 Migrer vers le dossier projet" Tag="{Binding}" Click="OnGridMediaCtxMigrate"
                                  ToolTip="Copie le fichier courant dans slides/{projet}/media/ et met à jour le lien"/>
                        <Separator/>
                        <MenuItem Header="✕ Retirer le média" Tag="{Binding}" Click="OnClearMediaClick"/>
                      </ContextMenu>
                    </Button.ContextMenu>
                    <StackPanel HorizontalAlignment="Center" MaxWidth="86">

                      <Grid Height="38">

                        <Image MaxHeight="38" MaxWidth="86" Stretch="Uniform"
                               RenderOptions.BitmapScalingMode="HighQuality"
                               Source="{Binding MediaPath, Converter={x:Static local:MediaThumbnailConverter.Instance}}"
                               Visibility="{Binding MediaPath, Converter={x:Static local:MediaHasImagePreviewConverter.Instance}}"/>

                        <TextBlock FontSize="22" HorizontalAlignment="Center" VerticalAlignment="Center"
                                   Foreground="{StaticResource Fg2}"
                                   Text="{Binding MediaPath, Converter={x:Static local:MediaBadgeIconConverter.Instance}}"
                                   Visibility="{Binding MediaPath, Converter={x:Static local:MediaNoImagePreviewConverter.Instance}}"/>

                        <Image MaxHeight="38" MaxWidth="86" Stretch="Uniform"
                               RenderOptions.BitmapScalingMode="HighQuality"
                               Source="{Binding Converter={x:Static local:MosaicThumbnailConverter.Instance}}"
                               Visibility="{Binding Converter={x:Static local:HasMosaicConverter.Instance}}"/>
                      </Grid>

                      <TextBlock Text="{Binding Converter={x:Static local:MosaicFileNameConverter.Instance}}"
                                 FontSize="8" FontFamily="Consolas" Foreground="{StaticResource Fg2}"
                                 TextTrimming="CharacterEllipsis" HorizontalAlignment="Center"
                                 MaxWidth="86" Margin="0,2,0,0"/>
                    </StackPanel>
                  </Button>
                </DataTemplate>
              </DataGridTemplateColumn.CellTemplate>
            </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="Audio" Width="110">
              <DataGridTemplateColumn.CellTemplate><DataTemplate>
                <Grid>
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="26"/>
                  </Grid.ColumnDefinitions>

                  <Button Grid.Column="0" Padding="2,3" Style="{StaticResource IconButton}" Tag="{Binding}"
                          Click="OnPickMp3Click" ToolTip="Clic = assigner audio &#xB7; Clic droit = options">
                    <Button.ContextMenu>

                      <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                        <MenuItem Header="&#x25BA; R&#xE9;&#xE9;couter" Tag="{Binding}" Click="OnPlayAudioClick"/>
                        <MenuItem Header="&#x23F9; Arr&#xEA;ter la lecture" Click="OnStopAudioPlayback"/>
                        <Separator/>
                        <MenuItem Header="Retirer l'audio" Tag="{Binding}" Click="OnClearMp3Click"/>
                      </ContextMenu>
                    </Button.ContextMenu>
                    <StackPanel HorizontalAlignment="Center" MaxWidth="72">
                      <Grid Height="38">

                        <TextBlock FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"
                                   Foreground="{StaticResource Fg2}">
                          <TextBlock.Style><Style TargetType="TextBlock">
                            <Setter Property="Text" Value="&#x1F3A4;"/>
                            <Style.Triggers>
                              <DataTrigger Binding="{Binding Mode}" Value="mp3">
                                <Setter Property="Text" Value="&#x1F3B5;"/>
                                <Setter Property="Foreground" Value="#E84118"/>
                              </DataTrigger>
                            </Style.Triggers>
                          </Style></TextBlock.Style>
                        </TextBlock>
                      </Grid>

                      <TextBlock FontSize="8" FontFamily="Consolas"
                                 TextTrimming="CharacterEllipsis" HorizontalAlignment="Center"
                                 MaxWidth="72" Margin="0,2,0,0"
                                 Text="{Binding Mp3, Converter={x:Static local:MediaFileNameConverter.Instance}}">
                        <TextBlock.Style><Style TargetType="TextBlock">
                          <Setter Property="Foreground" Value="{StaticResource Fg2}"/>
                          <Style.Triggers>
                            <DataTrigger Binding="{Binding Mode}" Value="mp3">
                              <Setter Property="Foreground" Value="#E84118"/>
                            </DataTrigger>
                          </Style.Triggers>
                        </Style></TextBlock.Style>
                      </TextBlock>
                    </StackPanel>
                  </Button>

                  <Button Grid.Column="1"
                          Padding="2,3" Style="{StaticResource IconButton}"
                          Tag="{Binding}"
                          Click="OnRecordClick"
                          ToolTip="Enregistrer depuis le micro">
                    <TextBlock FontSize="14" Text="&#x1F399;" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                  </Button>

                </Grid>
              </DataTemplate></DataGridTemplateColumn.CellTemplate>
            </DataGridTemplateColumn>
            <DataGridCheckBoxColumn Header="Txt" Width="36" Binding="{Binding ShowText}"/>

          </DataGrid.Columns></DataGrid></Grid>
      <Border Grid.Column="3" Style="{StaticResource VSep}"/>

      <DockPanel Grid.Column="4" Background="{StaticResource Bg2}" LastChildFill="True">
        <Border DockPanel.Dock="Top" BorderBrush="{StaticResource Line}" BorderThickness="0,0,0,1">
          <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" MaxHeight="560">
            <StackPanel Margin="10,8,10,8">
              <DockPanel Margin="0,0,0,4">
                <TextBlock Text="🎬 MÉDIA OVERLAY" FontSize="10" FontWeight="SemiBold" Foreground="{StaticResource Fg2}" VerticalAlignment="Center"/>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                  <Button x:Name="BtnExpandPreview" Content="⤢" FontSize="12" Style="{StaticResource IconButton}" Padding="5,2"
                          Click="OnToggleExpandPreview" ToolTip="Agrandir / réduire l'aperçu"/>
                  <Button Content="📂" FontSize="10" Style="{StaticResource IconButton}" Padding="5,2" Click="OnMediaPanelBrowse" ToolTip="Assigner un média"/>
                  <Button Content="✕" FontSize="10" Style="{StaticResource IconButton}" Padding="5,2" Click="OnMediaPanelClear" ToolTip="Retirer"/></StackPanel></DockPanel>

              <DockPanel Margin="0,2,0,6">
                <TextBlock Text="📷 Clip cam" DockPanel.Dock="Left" FontSize="10" FontWeight="SemiBold" Foreground="{StaticResource Fg2}" VerticalAlignment="Center"/>
