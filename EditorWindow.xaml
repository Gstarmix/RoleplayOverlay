                  <TextBox x:Name="MediaSpeedBox" Text="1.0" FontSize="10" TextChanged="OnMediaParamChanged" PreviewKeyDown="OnNumericFieldKeyDown"/></StackPanel></Grid>
              <Grid Margin="0,0,0,3"><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="6"/><ColumnDefinition/></Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0"><TextBlock Text="Bordure (px)" FontSize="9" Foreground="{StaticResource Fg2}" Margin="0,0,0,2"/>
                  <TextBox x:Name="MediaBorderBox" Text="6" FontSize="10" TextChanged="OnMediaParamChanged" PreviewKeyDown="OnNumericFieldKeyDown"/></StackPanel>
