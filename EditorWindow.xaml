                  <Button Content="▲" FontSize="9" Style="{StaticResource IconButton}" Padding="3,0" MinWidth="18" Height="20" Click="OnMediaItemMoveUp" ToolTip="Monter" Margin="0,0,1,0"/>
                  <Button Content="▼" FontSize="9" Style="{StaticResource IconButton}" Padding="3,0" MinWidth="18" Height="20" Click="OnMediaItemMoveDown" ToolTip="Descendre" Margin="0,0,2,0"/>
                  <Button Content="−" FontSize="14" Style="{StaticResource IconButton}" Padding="4,0" MinWidth="22" Height="20" Click="OnMediaItemRemove" ToolTip="Supprimer le media selectionne"/>
