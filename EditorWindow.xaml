              <DataGridTextColumn.ElementStyle><Style TargetType="TextBlock"><Setter Property="Foreground" Value="{StaticResource Fg2}"/><Setter Property="Padding" Value="6,0"/></Style></DataGridTextColumn.ElementStyle></DataGridTextColumn>
            <DataGridTemplateColumn Header="Paire" Width="38" IsReadOnly="True"><DataGridTemplateColumn.CellTemplate><DataTemplate>
              <Border Background="{Binding PairId, Converter={x:Static local:PairColorConverter.Instance}}"
