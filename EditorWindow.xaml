                <TextBlock Text="Ombre α :" FontSize="9" Foreground="{StaticResource Fg2}" VerticalAlignment="Center" Margin="0,0,4,0"/>
                <TextBox x:Name="MediaShadowAlphaBox" Text="0.55" Width="42" FontSize="10" TextChanged="OnMediaParamChanged" PreviewKeyDown="OnNumericFieldKeyDown"/>
                <CheckBox x:Name="MediaLoopCheck" Content="Boucler" FontSize="9" IsChecked="True" Margin="12,0,0,0"
                          Checked="OnMediaParamChanged" Unchecked="OnMediaParamChanged"/></StackPanel>
              <CheckBox x:Name="MediaUnlinkCheck" Content="🔓 Déconnecter du sibling" FontSize="9" Margin="0,2,0,4"
                        Visibility="Collapsed" ToolTip="Si coché, le média de cette séquence ne sera PAS propagé à sa paire FR/EN"
                        Checked="OnMediaUnlinkChanged" Unchecked="OnMediaUnlinkChanged"/>

              <Border x:Name="ScrubberPanel" Visibility="Collapsed" Background="#08FFFFFF" CornerRadius="4" Padding="8,6" Margin="0,2,0,4">
                <StackPanel>
                  <DockPanel Margin="0,0,0,5">
                    <TextBlock Text="✂ TRIM &amp; SCRUBBER" FontSize="9" FontWeight="SemiBold" Foreground="{StaticResource Fg2}" VerticalAlignment="Center"/>
                    <TextBlock x:Name="ScrubberDurationLabel" DockPanel.Dock="Right" Text="0:00" FontSize="9" Foreground="{StaticResource Fg2}" FontFamily="Consolas" VerticalAlignment="Center"/>
                  </DockPanel>
                  <Border x:Name="TrimGuidePanel" Background="#0D1A2A" BorderBrush="#1E3A5A" BorderThickness="1" CornerRadius="4" Padding="6,5" Margin="0,0,0,6">
                    <DockPanel>
                      <Button DockPanel.Dock="Right" Content="✕" Style="{StaticResource IconButton}" Padding="4,1" FontSize="9" Margin="4,0,0,0"
                              Click="OnDismissTrimGuide" ToolTip="Fermer le guide"/>
                      <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Background="#1A2A3A" CornerRadius="3" Padding="5,2"><TextBlock Text="1  Glisser" FontSize="9" Foreground="#6AB0DD"/></Border>
                        <TextBlock Text="→" FontSize="9" Foreground="#445566" VerticalAlignment="Center" Margin="4,0"/>
                        <Border Background="#1A2A3A" CornerRadius="3" Padding="5,2"><TextBlock Text="2  In ▼" FontSize="9" Foreground="#4DC93C"/></Border>
                        <TextBlock Text="→" FontSize="9" Foreground="#445566" VerticalAlignment="Center" Margin="4,0"/>
                        <Border Background="#1A2A3A" CornerRadius="3" Padding="5,2"><TextBlock Text="3  Out ▼" FontSize="9" Foreground="#E84118"/></Border>
                      </StackPanel>
                    </DockPanel>
                  </Border>
                  <TextBlock x:Name="ScrubberCurrentTimeLabel" Text="0.0s"
                             FontFamily="Consolas" FontSize="11" FontWeight="SemiBold" Foreground="White"
                             HorizontalAlignment="Center" TextWrapping="Wrap"
                             TextAlignment="Center" Margin="0,0,0,4"/>
                  <Slider x:Name="ScrubberSlider" Minimum="0" Maximum="1" Value="0" IsSnapToTickEnabled="False" TickFrequency="0.1"
                          ValueChanged="OnScrubberValueChanged" Margin="0,0,0,4" ToolTip="Déplacer pour prévisualiser une frame"/>
                  <Grid x:Name="TrimBarContainer" Height="18" Margin="0,0,0,6" SizeChanged="OnTrimBarContainerSizeChanged">
                    <Border Background="#222" CornerRadius="4"/>
                    <Thumb x:Name="TrimRangeBar" Width="0" Height="18" Cursor="SizeAll" DragStarted="OnTrimDragStarted" DragDelta="OnTrimRangeDragDelta" ToolTip="Glisser la plage"><Thumb.Template><ControlTemplate TargetType="Thumb"><Border Background="#44E84118" CornerRadius="2"/></ControlTemplate></Thumb.Template></Thumb>
                    <Canvas x:Name="TrimBarCanvas">
                      <Border x:Name="ScrubberPositionLine" Width="2" Height="18" Background="#80FFFFFF" Canvas.Left="0" IsHitTestVisible="False"/>
                      <Thumb x:Name="TrimInHandle" Width="8" Height="18" Canvas.Left="0"
                             DragStarted="OnTrimDragStarted" DragDelta="OnTrimInDragDelta" Cursor="SizeWE" ToolTip="Glisser : point In">
                        <Thumb.Template><ControlTemplate TargetType="Thumb"><Border Background="#FF4DC93C" CornerRadius="2"/></ControlTemplate></Thumb.Template>
                      </Thumb>
                      <Thumb x:Name="TrimOutHandle" Width="8" Height="18" Canvas.Left="0"
                             DragStarted="OnTrimDragStarted" DragDelta="OnTrimOutDragDelta" Cursor="SizeWE" ToolTip="Glisser : point Out">
                        <Thumb.Template><ControlTemplate TargetType="Thumb"><Border Background="#FFE84118" CornerRadius="2"/></ControlTemplate></Thumb.Template>
                      </Thumb>
                    </Canvas>
                  </Grid>

                  <Border Background="#0D0D0F" CornerRadius="4" ClipToBounds="True" Margin="0,0,0,6" MouseLeftButtonDown="OnScrubberThumbClick">
                    <Grid>
                      <Image x:Name="ScrubberThumb" Height="180" Stretch="Uniform" RenderOptions.BitmapScalingMode="HighQuality"/>
                      <TextBlock Text="🔍 Double-clic = popup HD" FontSize="9" Foreground="#55FFFFFF"
                                 HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,6,4" IsHitTestVisible="False"/>
                    </Grid>
                  </Border>
                  <Grid Margin="0,0,0,4">
                    <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/><ColumnDefinition/></Grid.ColumnDefinitions>
                    <Button x:Name="BtnSetIn" Grid.Column="0" Content="◀ In ici" Style="{StaticResource DarkButton}" Padding="6,5" FontSize="10"
                            HorizontalAlignment="Stretch" Click="OnSetTrimInHere" ToolTip="Placer le In au timestamp courant">
                      <Button.Foreground><SolidColorBrush Color="#4DC93C"/></Button.Foreground></Button>
                    <Button Content="✕" Grid.Column="1" Style="{StaticResource IconButton}" Padding="8,5" FontSize="10" Margin="4,0"
                            Click="OnResetTrim" ToolTip="Supprimer les points de trim"/>
                    <Button x:Name="BtnSetOut" Grid.Column="2" Content="Out ici ▶" Style="{StaticResource DarkButton}" Padding="6,5" FontSize="10"
                            HorizontalAlignment="Stretch" Click="OnSetTrimOutHere" ToolTip="Placer le Out au timestamp courant">
                      <Button.Foreground><SolidColorBrush Color="#E84118"/></Button.Foreground></Button>
                  </Grid>
                  <Grid Margin="0,0,0,2"><Grid.ColumnDefinitions>
                    <ColumnDefinition/><ColumnDefinition Width="6"/><ColumnDefinition/><ColumnDefinition Width="6"/><ColumnDefinition/>
                  </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                      <TextBlock FontSize="9" Margin="0,0,0,2"><Run Foreground="#4DC93C" FontWeight="SemiBold" Text="▶ In"/><Run Foreground="{StaticResource Fg2}" Text=" (sec)"/></TextBlock>
                      <TextBox x:Name="TrimInBox" Text="" FontSize="10" FontFamily="Consolas" ToolTip="↑↓=±0.1s" LostFocus="OnTrimChanged" PreviewKeyDown="OnTrimFieldKeyDown"/></StackPanel>
                    <StackPanel Grid.Column="2">
                      <TextBlock FontSize="9" Margin="0,0,0,2"><Run Foreground="#E84118" FontWeight="SemiBold" Text="◀ Out"/><Run Foreground="{StaticResource Fg2}" Text=" (sec)"/></TextBlock>
                      <TextBox x:Name="TrimOutBox" Text="" FontSize="10" FontFamily="Consolas" ToolTip="↑↓=±0.1s" LostFocus="OnTrimChanged" PreviewKeyDown="OnTrimFieldKeyDown"/></StackPanel>
                    <StackPanel Grid.Column="4">
                      <TextBlock Text="Durée trim" FontSize="9" Foreground="{StaticResource Fg2}" Margin="0,0,0,2"/>
                      <TextBlock x:Name="TrimDurationLabel" Text="—" FontSize="11" FontWeight="SemiBold" FontFamily="Consolas"
                                 Foreground="#FFA040" VerticalAlignment="Center" Padding="0,5"/></StackPanel>
                  </Grid>
                </StackPanel>
              </Border>

              <Border x:Name="CropPanel" Background="#08FFFFFF" CornerRadius="4" Padding="8,6" Margin="0,2,0,4">
                <StackPanel>
                  <Button Content="🎨 Annoter le slide" Style="{StaticResource IconButton}"
                          Padding="6,2" FontSize="9" Margin="0,2,0,2"
                          Click="OnOpenImageEditor" ToolTip="Ouvrir l'éditeur d'image sur le slide"/>
                  <DockPanel Margin="0,0,0,4">
                    <TextBlock Text="✂ RECADRAGE (px)" FontSize="9" FontWeight="SemiBold" Foreground="{StaticResource Fg2}" VerticalAlignment="Center"/>
                    <Button DockPanel.Dock="Right" Content="✕ Reset" Style="{StaticResource IconButton}" Padding="6,2" FontSize="9" Click="OnResetCrop" ToolTip="Remettre tous les crops à 0"/>
                    <Button DockPanel.Dock="Right" Content="🖱 Interactif" Style="{StaticResource IconButton}" Padding="6,2" FontSize="9" Margin="0,0,4,0"
                            Click="OnOpenCropEditor" ToolTip="Ouvrir l'éditeur de recadrage interactif"/></DockPanel>
                  <Grid Margin="0,0,0,3"><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="6"/><ColumnDefinition/></Grid.ColumnDefinitions>
                    <Grid.RowDefinitions><RowDefinition/><RowDefinition Height="4"/><RowDefinition/></Grid.RowDefinitions>
                    <StackPanel Grid.Row="0" Grid.Column="0"><TextBlock Text="Haut (T)" FontSize="9" Foreground="{StaticResource Fg2}" Margin="0,0,0,2"/>
                      <TextBox x:Name="CropTopBox" Text="0" FontSize="10" FontFamily="Consolas" LostFocus="OnCropChanged" PreviewKeyDown="OnCropFieldKeyDown"/></StackPanel>
                    <StackPanel Grid.Row="0" Grid.Column="2"><TextBlock Text="Bas (B)" FontSize="9" Foreground="{StaticResource Fg2}" Margin="0,0,0,2"/>
                      <TextBox x:Name="CropBottomBox" Text="0" FontSize="10" FontFamily="Consolas" LostFocus="OnCropChanged" PreviewKeyDown="OnCropFieldKeyDown"/></StackPanel>
                    <StackPanel Grid.Row="2" Grid.Column="0"><TextBlock Text="Gauche (L)" FontSize="9" Foreground="{StaticResource Fg2}" Margin="0,0,0,2"/>
                      <TextBox x:Name="CropLeftBox" Text="0" FontSize="10" FontFamily="Consolas" LostFocus="OnCropChanged" PreviewKeyDown="OnCropFieldKeyDown"/></StackPanel>
                    <StackPanel Grid.Row="2" Grid.Column="2"><TextBlock Text="Droite (R)" FontSize="9" Foreground="{StaticResource Fg2}" Margin="0,0,0,2"/>
                      <TextBox x:Name="CropRightBox" Text="0" FontSize="10" FontFamily="Consolas" LostFocus="OnCropChanged" PreviewKeyDown="OnCropFieldKeyDown"/></StackPanel>
                  </Grid>

                  <DockPanel Margin="0,6,0,0">
                    <TextBlock Text="Ancrage" FontSize="9" Foreground="{StaticResource Fg2}"
                               VerticalAlignment="Center" Margin="0,0,8,0" DockPanel.Dock="Left"/>
                    <UniformGrid x:Name="GravityGrid" Rows="3" Columns="3" Width="72" HorizontalAlignment="Left">
                      <Button x:Name="GravTL" Tag="topleft"     Content="↖" Style="{StaticResource IconButton}" Width="22" Height="22" Padding="0" FontSize="13" Click="OnGravityClick" ToolTip="Haut-Gauche"/>
                      <Button x:Name="GravT"  Tag="top"         Content="↑" Style="{StaticResource IconButton}" Width="22" Height="22" Padding="0" FontSize="13" Click="OnGravityClick" ToolTip="Haut"/>
                      <Button x:Name="GravTR" Tag="topright"    Content="↗" Style="{StaticResource IconButton}" Width="22" Height="22" Padding="0" FontSize="13" Click="OnGravityClick" ToolTip="Haut-Droite"/>
                      <Button x:Name="GravL"  Tag="left"        Content="←" Style="{StaticResource IconButton}" Width="22" Height="22" Padding="0" FontSize="13" Click="OnGravityClick" ToolTip="Gauche"/>
                      <Button x:Name="GravC"  Tag="center"      Content="●" Style="{StaticResource IconButton}" Width="22" Height="22" Padding="0" FontSize="13" Click="OnGravityClick" ToolTip="Centre (défaut)" Background="#33FF8000"/>
                      <Button x:Name="GravR"  Tag="right"       Content="→" Style="{StaticResource IconButton}" Width="22" Height="22" Padding="0" FontSize="13" Click="OnGravityClick" ToolTip="Droite"/>
                      <Button x:Name="GravBL" Tag="bottomleft"  Content="↙" Style="{StaticResource IconButton}" Width="22" Height="22" Padding="0" FontSize="13" Click="OnGravityClick" ToolTip="Bas-Gauche"/>
                      <Button x:Name="GravB"  Tag="bottom"      Content="↓" Style="{StaticResource IconButton}" Width="22" Height="22" Padding="0" FontSize="13" Click="OnGravityClick" ToolTip="Bas"/>
                      <Button x:Name="GravBR" Tag="bottomright" Content="↘" Style="{StaticResource IconButton}" Width="22" Height="22" Padding="0" FontSize="13" Click="OnGravityClick" ToolTip="Bas-Droite"/>
                    </UniformGrid>
                  </DockPanel>

                  <DockPanel Margin="0,6,0,0">
                    <TextBlock Text="Position" FontSize="9" Foreground="{StaticResource Fg2}"
                               VerticalAlignment="Center" Margin="0,0,8,0" DockPanel.Dock="Left"
                               ToolTip="Où le média apparaît PAR-DESSUS la base (diapo ou clip composé/cam)"/>
                    <UniformGrid x:Name="AnchorGrid" Rows="3" Columns="3" Width="72" HorizontalAlignment="Left">
                      <Button x:Name="AnchTL" Tag="topleft"     Content="↖" Style="{StaticResource IconButton}" Width="22" Height="22" Padding="0" FontSize="13" Click="OnAnchorClick" ToolTip="Haut-Gauche"/>
                      <Button x:Name="AnchT"  Tag="top"         Content="↑" Style="{StaticResource IconButton}" Width="22" Height="22" Padding="0" FontSize="13" Click="OnAnchorClick" ToolTip="Haut"/>
                      <Button x:Name="AnchTR" Tag="topright"    Content="↗" Style="{StaticResource IconButton}" Width="22" Height="22" Padding="0" FontSize="13" Click="OnAnchorClick" ToolTip="Haut-Droite"/>
                      <Button x:Name="AnchL"  Tag="left"        Content="←" Style="{StaticResource IconButton}" Width="22" Height="22" Padding="0" FontSize="13" Click="OnAnchorClick" ToolTip="Gauche"/>
                      <Button x:Name="AnchC"  Tag="center"      Content="●" Style="{StaticResource IconButton}" Width="22" Height="22" Padding="0" FontSize="13" Click="OnAnchorClick" ToolTip="Centre (défaut)" Background="#33FF8000"/>
                      <Button x:Name="AnchR"  Tag="right"       Content="→" Style="{StaticResource IconButton}" Width="22" Height="22" Padding="0" FontSize="13" Click="OnAnchorClick" ToolTip="Droite"/>
                      <Button x:Name="AnchBL" Tag="bottomleft"  Content="↙" Style="{StaticResource IconButton}" Width="22" Height="22" Padding="0" FontSize="13" Click="OnAnchorClick" ToolTip="Bas-Gauche"/>
                      <Button x:Name="AnchB"  Tag="bottom"      Content="↓" Style="{StaticResource IconButton}" Width="22" Height="22" Padding="0" FontSize="13" Click="OnAnchorClick" ToolTip="Bas"/>
                      <Button x:Name="AnchBR" Tag="bottomright" Content="↘" Style="{StaticResource IconButton}" Width="22" Height="22" Padding="0" FontSize="13" Click="OnAnchorClick" ToolTip="Bas-Droite"/>
                    </UniformGrid>
                  </DockPanel>
                </StackPanel></Border>

              <Border Background="#08FFFFFF" CornerRadius="4" Padding="8,5" Margin="0,4,0,0">
                <StackPanel>
                  <TextBlock Text="OPTIONS PREVIEW" FontSize="9" FontWeight="SemiBold" Foreground="{StaticResource Fg2}" Margin="0,0,0,4"/>
                  <CheckBox x:Name="PvIncludeAvatar" Content="Avatar + glow" FontSize="9" IsChecked="False" Margin="0,0,0,2"
                            ToolTip="Inclure avatar circulaire, ring et halo (plus lent)"/>
                  <CheckBox x:Name="PvIncludeShadow" Content="Ombre media" FontSize="9" IsChecked="False" Margin="0,0,0,2"
                            ToolTip="Inclure ombre sur le media overlay (plus lent)"/>
                  <CheckBox x:Name="PvIncludeSubs" Content="Sous-titres" FontSize="9" IsChecked="False" Margin="0,0,0,2"
                            ToolTip="Graver les sous-titres dans la preview"/>
                  <CheckBox x:Name="PvFullFps" Content="25 fps (au lieu de 15)" FontSize="9" IsChecked="False" Margin="0,0,0,0"
                            ToolTip="Framerate complet (plus lent mais plus fluide)"/>
                </StackPanel>
              </Border>
              <Button x:Name="BtnPreviewFrame" Content="👁 Aperçu composé" Style="{StaticResource DarkButton}" Padding="8,5"
                      HorizontalAlignment="Stretch" Margin="0,2,0,0" Click="OnPreviewFrame"
                      ToolTip="PNG compose pour chaque segment selectionne (un par Note unique)"/>
              <Button x:Name="BtnPreviewSegment" Content="▶ Prévisualiser ce segment" Style="{StaticResource AccentButton}" Padding="8,5"
                      HorizontalAlignment="Stretch" Margin="0,4,0,0" Click="OnPreviewSegment"
                      ToolTip="Genere et ouvre un MP4 de prévisualisation du segment selectionne"/>
            </StackPanel>
          </ScrollViewer>
        </Border>

        <TabControl Background="Transparent" BorderThickness="0" Padding="0" Margin="0">
          <TabControl.Resources>
            <Style TargetType="TabItem">
              <Setter Property="Foreground" Value="{StaticResource Fg2}"/><Setter Property="Background" Value="Transparent"/>
              <Setter Property="Padding" Value="12,6"/><Setter Property="FontSize" Value="11"/><Setter Property="FontWeight" Value="SemiBold"/>
              <Setter Property="Template"><Setter.Value><ControlTemplate TargetType="TabItem">
                <Border x:Name="Bd" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}" BorderThickness="0,0,0,2" BorderBrush="Transparent">
                  <ContentPresenter ContentSource="Header" HorizontalAlignment="Center"/></Border>
                <ControlTemplate.Triggers>
                  <Trigger Property="IsSelected" Value="True"><Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource Accent}"/><Setter Property="Foreground" Value="{StaticResource Fg}"/></Trigger>
                  <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="Bd" Property="Background" Value="#0AFFFFFF"/></Trigger>
                </ControlTemplate.Triggers></ControlTemplate></Setter.Value></Setter></Style>
          </TabControl.Resources>
          <TabItem Header="⚙ Configuration">
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
              <StackPanel Margin="10,10,10,10">
                <local:BubbleConfigControl x:Name="BubbleConfig" Margin="0,0,0,8"/>
                <Border Height="1" Background="{StaticResource Line}" Margin="0,0,0,8"/>
                <Border Background="#0DFFFFFF" CornerRadius="4" Padding="8,6" Margin="0,0,0,8"><StackPanel>
                  <TextBlock Text="VOIX TTS" FontSize="10" FontWeight="SemiBold" Foreground="{StaticResource Fg2}" Margin="0,0,0,6"/>
                  <RadioButton x:Name="TtsModeSapi" GroupName="TtsMode" IsChecked="False" Margin="0,0,0,5" Foreground="{StaticResource Fg}">
                    <StackPanel><TextBlock Text="🔧 Mode test — SAPI" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource Fg}"/>
                      <TextBlock Text="Voix basique, 0 crédit" FontSize="10" Foreground="{StaticResource Fg2}"/></StackPanel></RadioButton>
                  <RadioButton x:Name="TtsModeAzure" GroupName="TtsMode" IsChecked="True" Foreground="{StaticResource Fg}">
                    <StackPanel><TextBlock Text="🎙 Production — Azure Neural" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource LangEN}"/>
                      <TextBlock Text="HenriNeural / GuyNeural" FontSize="10" Foreground="{StaticResource Fg2}"/></StackPanel></RadioButton></StackPanel></Border>
                <Border Background="#0DFFFFFF" CornerRadius="4" Padding="8,6" Margin="0,0,0,8"><StackPanel>
                  <CheckBox x:Name="ShowAvatarsCheck" Content="Afficher les avatars" IsChecked="True" Margin="0,0,0,6"/>
                  <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <TextBlock Text="Intensité halo :" Foreground="{StaticResource Fg2}" FontSize="11" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBox x:Name="GlowIntensityBox" Text="0.7" Width="48" FontSize="11"/></StackPanel>
                  <CheckBox x:Name="BurnSubsCheck" Content="Graver les sous-titres" IsChecked="True" Margin="0,0,0,8"/>
                  <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <TextBlock Text="Taille sous-titres :" Foreground="{StaticResource Fg2}" FontSize="11" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBox x:Name="SubFontSizeBox" Text="50" Width="50" FontSize="11"/>
                    <TextBlock Text="px" Foreground="{StaticResource Fg2}" FontSize="11" VerticalAlignment="Center" Margin="4,0,0,0"/></StackPanel>
                  <TextBlock Text="COULEURS SOUS-TITRES" FontSize="10" FontWeight="SemiBold" Foreground="{StaticResource Fg2}" Margin="0,0,0,6"/>
                  <Grid><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="6"/><ColumnDefinition/></Grid.ColumnDefinitions>
                    <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="4"/><RowDefinition Height="Auto"/><RowDefinition Height="4"/><RowDefinition Height="Auto"/><RowDefinition Height="4"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Texte" FontSize="9" Foreground="{StaticResource Fg2}" HorizontalAlignment="Center" Margin="0,0,0,2"/>
                    <TextBlock Grid.Row="0" Grid.Column="2" Text="Contour" FontSize="9" Foreground="{StaticResource Fg2}" HorizontalAlignment="Center" Margin="0,0,0,2"/>
                    <Button x:Name="SubB1PrimaryBtn" Grid.Row="2" Grid.Column="0" Height="22" Background="#FFFF00FF" BorderBrush="White" BorderThickness="1" Cursor="Hand" Click="OnPickSubB1Primary"><TextBlock Text="B1" FontSize="9" FontWeight="Bold" Foreground="White"/></Button>
                    <Button x:Name="SubB1OutlineBtn" Grid.Row="2" Grid.Column="2" Height="22" Background="#FFFFFFFF" BorderBrush="{StaticResource Line}" BorderThickness="1" Cursor="Hand" Click="OnPickSubB1Outline"><TextBlock Text="B1" FontSize="9" FontWeight="Bold" Foreground="Black"/></Button>
                    <Button x:Name="SubB2PrimaryBtn" Grid.Row="4" Grid.Column="0" Height="22" Background="#FF00FFFF" BorderBrush="White" BorderThickness="1" Cursor="Hand" Click="OnPickSubB2Primary"><TextBlock Text="B2" FontSize="9" FontWeight="Bold" Foreground="Black"/></Button>
                    <Button x:Name="SubB2OutlineBtn" Grid.Row="4" Grid.Column="2" Height="22" Background="#FFFFFFFF" BorderBrush="{StaticResource Line}" BorderThickness="1" Cursor="Hand" Click="OnPickSubB2Outline"><TextBlock Text="B2" FontSize="9" FontWeight="Bold" Foreground="Black"/></Button>
                    <Button x:Name="SubYouPrimaryBtn" Grid.Row="6" Grid.Column="0" Height="22" Background="#FFFFD400" BorderBrush="White" BorderThickness="1" Cursor="Hand" Click="OnPickSubYouPrimary"><TextBlock Text="YOU" FontSize="9" FontWeight="Bold" Foreground="Black"/></Button>
                    <Button x:Name="SubYouOutlineBtn" Grid.Row="6" Grid.Column="2" Height="22" Background="#FFFFFFFF" BorderBrush="{StaticResource Line}" BorderThickness="1" Cursor="Hand" Click="OnPickSubYouOutline"><TextBlock Text="YOU" FontSize="9" FontWeight="Bold" Foreground="Black"/></Button></Grid>
                </StackPanel></Border>
              </StackPanel>
            </ScrollViewer>
          </TabItem>
          <TabItem Header="🎬 Export">
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
              <StackPanel Margin="10,10,10,10">
                <TextBlock Text="Dossier sortie MP4 :" Foreground="{StaticResource Fg2}" FontSize="11" Margin="0,0,0,4"/>
                <DockPanel Margin="0,0,0,8"><Button DockPanel.Dock="Right" Content="…" Style="{StaticResource IconButton}" Margin="6,0,0,0" Click="OnBrowseOutputDir"/>
                  <TextBox x:Name="OutputDirBox" FontFamily="Consolas" FontSize="11"/></DockPanel>
                <TextBlock Text="Chemin ffmpeg.exe (vide = PATH) :" Foreground="{StaticResource Fg2}" FontSize="11" Margin="0,0,0,4"/>
                <DockPanel Margin="0,0,0,8"><Button DockPanel.Dock="Right" Content="…" Style="{StaticResource IconButton}" Margin="6,0,0,0" Click="OnBrowseFfmpeg"/>
                  <TextBox x:Name="FfmpegPathBox" FontFamily="Consolas" FontSize="11"/></DockPanel>
                <TextBlock Text="Format vidéo :" Foreground="{StaticResource Fg2}" FontSize="11" Margin="0,0,0,4"/>
                <ComboBox x:Name="VideoAspectBox" Margin="0,0,0,8" FontSize="11"
                          SelectionChanged="OnVideoAspectChanged"
                          ToolTip="Paysage = YouTube classique. Vertical = Reels/TikTok/Shorts (les positions avatars et la taille des sous-titres sont automatiquement adaptées).">
                  <ComboBoxItem Tag="Landscape" IsSelected="True">Paysage 1920×1080 (YouTube)</ComboBoxItem>
                  <ComboBoxItem Tag="Portrait">Vertical 1080×1920 (Reels / TikTok / Shorts)</ComboBoxItem>
                </ComboBox>
                <Grid Margin="0,0,0,8"><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="10"/><ColumnDefinition/></Grid.ColumnDefinitions>
                  <StackPanel Grid.Column="0"><TextBlock Text="CRF (qualité)" Foreground="{StaticResource Fg2}" FontSize="11" Margin="0,0,0,4"/>
                    <TextBox x:Name="CrfBox" Text="18" FontSize="12"/></StackPanel>
                  <StackPanel Grid.Column="2"><TextBlock Text="Taille police" Foreground="{StaticResource Fg2}" FontSize="11" Margin="0,0,0,4"/>
                    <TextBox x:Name="FontSizeBox" Text="34" FontSize="12"/></StackPanel></Grid>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                  <TextBlock Text="Segments en parallèle :" Foreground="{StaticResource Fg2}" FontSize="11" VerticalAlignment="Center" Margin="0,0,8,0"/>
                  <TextBox x:Name="ParallelBox" Text="0" Width="36" FontSize="11" ToolTip="0 = auto"/>
                  <TextBlock Text="(0 = auto)" Foreground="{StaticResource Fg2}" FontSize="10" VerticalAlignment="Center" Margin="6,0,0,0"/></StackPanel>
                <CheckBox x:Name="UseNvencCheck" Content="Encoder avec NVIDIA NVENC (GPU)" IsChecked="True" Margin="0,0,0,12" FontSize="11"/>

                <Border Background="#08FFFFFF" CornerRadius="4" Padding="8,6" Margin="0,0,0,10">
                  <StackPanel>
                    <TextBlock Text="📁 Organisation des fichiers" FontSize="10" FontWeight="SemiBold"
                               Foreground="{StaticResource Fg2}" Margin="0,0,0,6"/>
                    <TextBlock TextWrapping="Wrap" FontSize="10" Foreground="{StaticResource Fg2}" Margin="0,0,0,6"
                               Text="Copie tous les médias et audios du projet vers leurs dossiers dédiés (slides/{projet}/media/ et audio/) avec un nom cohérent. Rétroactif pour les fichiers déjà assignés."/>
                    <Button Content="📂 Réorganiser tous les médias" Style="{StaticResource DarkButton}"
                            HorizontalAlignment="Stretch" Padding="8,6" FontSize="11"
                            Click="OnReorganizeAllAssets"
                            ToolTip="Copie + renomme tous les médias/audios existants dans le dossier projet"/>
                  </StackPanel>
                </Border>

                <Button x:Name="BtnExportAll" Content="⬛⬛ Exporter toutes les scènes"
                        Style="{StaticResource DarkButton}"
                        HorizontalAlignment="Stretch" Padding="8,6"
                        Margin="0,0,0,6"
                        Click="OnExportAllScenes"
                        ToolTip="Exporte chaque scène du projet en MP4 séquentiellement (file d'attente)"/>

                <Button x:Name="BtnExportBottom" Content="⬛ EXPORTER MP4" Style="{StaticResource AccentButton}"
                        HorizontalAlignment="Stretch" Padding="12,10" Click="OnExportMp4"/>
              </StackPanel>
            </ScrollViewer>
          </TabItem>

          <TabItem Header="📜 Historique">
            <Grid Margin="10,8,10,8">
              <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="8"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
              </Grid.RowDefinitions>

              <DockPanel Grid.Row="0" Margin="0,0,0,4">
                <TextBlock Text="↩ ANNULER" FontSize="10" FontWeight="SemiBold"
                           Foreground="{StaticResource LangEN}" VerticalAlignment="Center"/>
                <TextBlock x:Name="UndoCountLabel" DockPanel.Dock="Right"
                           FontSize="10" Foreground="{StaticResource Fg2}"
                           FontFamily="Consolas" VerticalAlignment="Center" Text="0"/>
              </DockPanel>

              <ListBox x:Name="UndoHistoryList" Grid.Row="1"
                       Background="#08FFFFFF" BorderBrush="{StaticResource Line}" BorderThickness="1"
                       Foreground="{StaticResource Fg}" FontSize="11"
                       ScrollViewer.VerticalScrollBarVisibility="Auto"
                       SelectionChanged="OnUndoHistorySelected">
                <ListBox.ItemContainerStyle>
                  <Style TargetType="ListBoxItem">
                    <Setter Property="Padding" Value="8,5"/>
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Foreground" Value="{StaticResource Fg}"/>
                    <Setter Property="Cursor" Value="Hand"/>
                    <Style.Triggers>
                      <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="#14FFFFFF"/>
                      </Trigger>
                      <Trigger Property="IsSelected" Value="True">
                        <Setter Property="Background" Value="#334DC93C"/>
                      </Trigger>
                    </Style.Triggers>
                  </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                  <DataTemplate>
                    <StackPanel Orientation="Horizontal">
                      <TextBlock Text="{Binding Index}" Width="26" Foreground="{StaticResource Fg2}"
                                 FontFamily="Consolas" FontSize="10" VerticalAlignment="Center"/>
                      <TextBlock Text="↩ " Foreground="{StaticResource LangEN}" VerticalAlignment="Center"/>
                      <TextBlock Text="{Binding Label}" VerticalAlignment="Center"/>
                    </StackPanel>
                  </DataTemplate>
                </ListBox.ItemTemplate>
              </ListBox>

              <Border Grid.Row="2" Height="1" Background="{StaticResource Line}" VerticalAlignment="Center"/>

              <DockPanel Grid.Row="3" Margin="0,4,0,4">
                <TextBlock Text="↪ RÉTABLIR" FontSize="10" FontWeight="SemiBold"
                           Foreground="{StaticResource Accent}" VerticalAlignment="Center"/>
                <TextBlock x:Name="RedoCountLabel" DockPanel.Dock="Right"
                           FontSize="10" Foreground="{StaticResource Fg2}"
                           FontFamily="Consolas" VerticalAlignment="Center" Text="0"/>
              </DockPanel>

              <ListBox x:Name="RedoHistoryList" Grid.Row="4"
                       Background="#08FFFFFF" BorderBrush="{StaticResource Line}" BorderThickness="1"
                       Foreground="{StaticResource Fg}" FontSize="11"
                       ScrollViewer.VerticalScrollBarVisibility="Auto"
                       SelectionChanged="OnRedoHistorySelected">
                <ListBox.ItemContainerStyle>
                  <Style TargetType="ListBoxItem">
                    <Setter Property="Padding" Value="8,5"/>
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Foreground" Value="{StaticResource Fg}"/>
                    <Setter Property="Cursor" Value="Hand"/>
                    <Style.Triggers>
                      <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="#14FFFFFF"/>
                      </Trigger>
                      <Trigger Property="IsSelected" Value="True">
                        <Setter Property="Background" Value="#33E84118"/>
                      </Trigger>
                    </Style.Triggers>
                  </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                  <DataTemplate>
                    <StackPanel Orientation="Horizontal">
                      <TextBlock Text="{Binding Index}" Width="26" Foreground="{StaticResource Fg2}"
                                 FontFamily="Consolas" FontSize="10" VerticalAlignment="Center"/>
                      <TextBlock Text="↪ " Foreground="{StaticResource Accent}" VerticalAlignment="Center"/>
                      <TextBlock Text="{Binding Label}" VerticalAlignment="Center"/>
                    </StackPanel>
                  </DataTemplate>
                </ListBox.ItemTemplate>
              </ListBox>
            </Grid>
          </TabItem>

        </TabControl>
      </DockPanel>
    </Grid>
  </Grid>
</Window>