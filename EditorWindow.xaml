                    <MenuItem Header="— Source originale —" IsEnabled="False" FontWeight="SemiBold"/>
                    <MenuItem Header="👁 Ouvrir la source originale" Click="OnMediaCtxViewSource"/>
                    <MenuItem Header="🗂 Source dans l'explorateur" Click="OnMediaCtxSourceInExplorer"/>
                    <Separator/>
                    <MenuItem Header="🔄 Migrer vers le dossier projet" Click="OnMediaCtxMigrate"
                              ToolTip="Copie le fichier courant dans slides/{projet}/media/ et met à jour le lien"/>
                    <Separator/>
                    <MenuItem Header="✏ Renommer (nom de projet)" Click="OnMediaCtxRename"
