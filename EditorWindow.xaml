                <TextBlock Text="{Binding IsPaired, Converter={x:Static local:PairBadgeConverter.Instance}}"
                           FontSize="12" HorizontalAlignment="Center" VerticalAlignment="Center"
                           ToolTip="{Binding PairId}"/>
              </Border>
            </DataTemplate></DataGridTemplateColumn.CellTemplate></DataGridTemplateColumn>

            <DataGridTemplateColumn Header="Durée" Width="52" IsReadOnly="True" SortMemberPath="EstimatedDuration">
              <DataGridTemplateColumn.CellTemplate><DataTemplate>
                <TextBlock Text="{Binding DurationDisplay}" FontSize="9" FontFamily="Consolas"
