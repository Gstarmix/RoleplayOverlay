              <MenuItem Header="+ Ajouter une ligne" Click="OnAdd"/>
              <MenuItem Header="&#x2715; Supprimer la ligne" Click="OnRemove"/>
              <Separator/>
              <MenuItem Header="&#x25B2; Monter" Click="OnUp"/>
