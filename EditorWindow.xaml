                <TextBlock x:Name="CamClipLabel" Text="aucun" FontSize="9" Foreground="#888" VerticalAlignment="Center" Margin="8,0,0,0" TextTrimming="CharacterEllipsis"/></DockPanel>

              <DockPanel Margin="0,2,0,6">
