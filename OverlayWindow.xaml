<Window x:Class="RoleplayOverlay.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="Roleplay Overlay"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        Loaded="Window_Loaded"
        Activated="Window_Activated">
  <Canvas x:Name="RootCanvas">

    <Grid x:Name="YouBubble" Width="140" Height="140" Visibility="Collapsed">
      <Ellipse x:Name="YouImage" StrokeThickness="0">
        <Ellipse.Fill>
          <ImageBrush Stretch="UniformToFill"/>
        </Ellipse.Fill>
      </Ellipse>
      <Ellipse x:Name="YouRing"  Fill="Transparent" Stroke="#CCFFFFFF" StrokeThickness="4"/>
      <Ellipse x:Name="YouPulse" Fill="Transparent" Stroke="#55FFFFFF" StrokeThickness="6" Opacity="0"/>
    </Grid>

    <Grid x:Name="Bot1Bubble" Width="140" Height="140" Visibility="Collapsed">
      <Ellipse x:Name="Bot1Image" StrokeThickness="0">
        <Ellipse.Fill>
          <ImageBrush Stretch="UniformToFill"/>
        </Ellipse.Fill>
      </Ellipse>
      <Ellipse x:Name="Bot1Ring"  Fill="Transparent" Stroke="#CCFFFFFF" StrokeThickness="4"/>
      <Ellipse x:Name="Bot1Pulse" Fill="Transparent" Stroke="#55FFFFFF" StrokeThickness="6" Opacity="0"/>
    </Grid>

    <Border x:Name="Bot1TextBox"
            Background="#AA000000"
            CornerRadius="10"
            Padding="8"
            Visibility="Collapsed">
      <Grid>

        <wv2:WebView2 x:Name="Bot1Html"
                      Visibility="Collapsed"
                      Width="420"
                      MinHeight="1"/>

        <TextBlock x:Name="Bot1Text"
                   Foreground="White"
                   FontSize="16"
                   TextWrapping="Wrap"
                   Width="420"/>

        <Button x:Name="Bot1Close"
                Content="✕"
                Width="24" Height="24"
                FontWeight="Bold"
                Foreground="White"
                Background="#33FFFFFF"
                BorderBrush="#55FFFFFF"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Margin="0,-6,-6,0"
                Padding="0"
                Click="OnCloseBot1"/>
      </Grid>
    </Border>

    <Grid x:Name="Bot2Bubble" Width="140" Height="140" Visibility="Collapsed">
      <Ellipse x:Name="Bot2Image" StrokeThickness="0">
        <Ellipse.Fill>
          <ImageBrush Stretch="UniformToFill"/>
        </Ellipse.Fill>
      </Ellipse>
      <Ellipse x:Name="Bot2Ring"  Fill="Transparent" Stroke="#CCFFFFFF" StrokeThickness="4"/>
      <Ellipse x:Name="Bot2Pulse" Fill="Transparent" Stroke="#55FFFFFF" StrokeThickness="6" Opacity="0"/>
    </Grid>

    <Border x:Name="Bot2TextBox"
            Background="#AA000000"
            CornerRadius="10"
            Padding="8"
            Visibility="Collapsed">
      <Grid>
        <wv2:WebView2 x:Name="Bot2Html"
                      Visibility="Collapsed"
                      Width="420"
                      MinHeight="1"/>
        <TextBlock x:Name="Bot2Text"
                   Foreground="White"
                   FontSize="16"
                   TextWrapping="Wrap"
                   Width="420"/>
        <Button x:Name="Bot2Close"
                Content="✕"
                Width="24" Height="24"
                FontWeight="Bold"
                Foreground="White"
                Background="#33FFFFFF"
                BorderBrush="#55FFFFFF"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Margin="0,-6,-6,0"
                Padding="0"
                Click="OnCloseBot2"/>
      </Grid>
    </Border>

  </Canvas>
</Window>